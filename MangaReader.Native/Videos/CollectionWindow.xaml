<Window x:Class="MangaReader.Native.Videos.CollectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MangaReader.Native.Controls"
        Title="合集" Height="700" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Loaded="CollectionWindow_Loaded">
    <Window.Resources>
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImageCardBorder" TargetType="Border">
            <Setter Property="Width" Value="142"/>
            <Setter Property="Height" Value="200"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="VideoCardBorder" TargetType="Border">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="170"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 标签页 -->
        <Border Grid.Row="0" Padding="20,16,20,0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock x:Name="FolderTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ItemCountText" FontSize="13"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button x:Name="ImageTabButton"
                            Style="{StaticResource TabButton}"
                            Tag="active"
                            Content="图库"
                            Click="ImageTab_Click"/>
                    <Button x:Name="VideoTabButton"
                            Style="{StaticResource TabButton}"
                            Content="视频集"
                            Click="VideoTab_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Row="1">
            <!-- 图库面板 -->
            <ListBox x:Name="ImageGalleryPanel"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseDoubleClick="ImageGallery_PreviewMouseDoubleClick"
                     Visibility="Visible">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel ItemWidth="152" ItemHeight="210"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ImageCardBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="142"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="4" Margin="6,6,6,0"
                                        Background="#1E293B" ClipToBounds="True">
                                    <TextBlock Text="{Binding FileTypeIcon}"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#475569"/>
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Name}"
                                           FontSize="11" Foreground="{DynamicResource Brush.TextPrimary}"
                                           Margin="8,4,8,6"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="28"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>

            <!-- 视频面板 -->
            <ListBox x:Name="VideoListPanel"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseDoubleClick="VideoList_PreviewMouseDoubleClick"
                     Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel ItemWidth="212" ItemHeight="182"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource VideoCardBorder}" ToolTip="{Binding Title}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="4"
                                        Margin="8,8,8,0"
                                        Background="#1E293B" ClipToBounds="True">
                                    <TextBlock Text="🎬" FontSize="32"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#475569"/>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="10,6,10,8">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="32" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DurationText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Margin="0,2,0,0" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Padding="20,8,20,10"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" FontSize="12"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Text="就绪"/>
        </Border>
    </Grid>
</Window>
