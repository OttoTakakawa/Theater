<Window x:Class="MangaReader.Native.Videos.VideoLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MangaReader.Native.Controls"
        Title="视频库" Height="800" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Loaded="VideoLibraryWindow_Loaded">
    <Window.Resources>
        <Style x:Key="VideoCardBorder" TargetType="Border">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="170"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Padding="20,16,20,12"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="📁 添加文件夹" Click="AddFolderButton_Click"
                        Style="{StaticResource AppButton}" MinHeight="32" Padding="12,6"/>
                <Button Grid.Column="1" Content="🔄 刷新" Click="RefreshButton_Click"
                        Style="{StaticResource AppButton}" MinHeight="32" Padding="12,6"
                        Margin="8,0,0,0"/>

                <TextBox Grid.Column="2" x:Name="SearchBox"
                         Width="240" MinHeight="32" Margin="12,0,12,0"
                         Style="{StaticResource AppDialogTextBox}"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock Grid.Column="4" x:Name="VideoCountText"
                           Text="0 个视频" FontSize="13"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
            </Grid>
        </Border>

        <!-- 视频列表 -->
        <Grid Grid.Row="1">
            <ListBox x:Name="VideoListBox"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="2,1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     SelectionMode="Single"
                     PreviewMouseDoubleClick="VideoListBox_PreviewMouseDoubleClick"
                     KeyDown="VideoListBox_KeyDown">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel ItemWidth="212" ItemHeight="182"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource VideoCardBorder}"
                                ToolTip="{Binding Title}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="4"
                                        Margin="8,8,8,0"
                                        Background="#1E293B" ClipToBounds="True">
                                    <TextBlock Text="🎬" FontSize="32"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#475569"/>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="10,6,10,8">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="32" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DurationText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Margin="0,2,0,0" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>

            <Border x:Name="EmptyState" Visibility="Collapsed" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="尚无视频" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Margin="0,12,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="点击上方「添加文件夹」来添加视频目录" FontSize="13"
                               Foreground="{DynamicResource Brush.Dim}"
                               Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Padding="20,8,20,10"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText"
                           Text="就绪" FontSize="12"
                           Foreground="{DynamicResource Brush.TextMuted}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="管理目录" Click="ManageRootsButton_Click"
                            Style="{StaticResource AppGhostButton}"
                            MinHeight="28" Padding="10,4" FontSize="11"
                            Margin="0,0,8,0"/>
                    <Button Content="❌ 关闭" Click="CloseButton_Click"
                            Style="{StaticResource AppGhostButton}"
                            MinHeight="28" Padding="10,4" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
