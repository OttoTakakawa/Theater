<Window x:Class="MangaReader.Native.TagNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑标签"
        Width="520"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="编辑标签" Style="{StaticResource AppDialogTitleText}"/>
                    <TextBlock Text="只修改标签名称；分类会根据内置预设或自定义规则自动归类。"
                               Style="{StaticResource AppDialogSubtitleText}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <TextBlock Text="标签名称" Style="{StaticResource AppDialogLabelText}"/>
                    <TextBox x:Name="TagNameBox"
                             Margin="0,8,0,0"
                             Style="{StaticResource AppDialogTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                    <Button Content="保存" Width="104" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
