<Window x:Class="MangaReader.Native.ReverseOrganizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="反向规整目录"
        Width="1120"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="反向规整目录"
                       FontSize="22"
                       FontWeight="Black"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBlock Text="安全导出版：只复制，不移动，不删除源目录，不修改数据库。执行前必须先预检，完成后写出 manifest。"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.SurfaceMuted}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="16"
                Margin="0,18,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="208"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="导出范围" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ScopeBox" Grid.Row="1" Style="{StaticResource AppDialogComboBox}" Height="36" SelectionChanged="Input_Changed">
                        <ComboBoxItem Content="全部漫画"/>
                        <ComboBoxItem Content="当前筛选结果"/>
                        <ComboBoxItem Content="当前选中漫画"/>
                        <ComboBoxItem Content="指定作者"/>
                    </ComboBox>
                    <ComboBox x:Name="AuthorBox" Grid.Row="2" Style="{StaticResource AppDialogComboBox}" Height="36" Margin="0,8,0,0" Visibility="Collapsed" SelectionChanged="Input_Changed"/>
                    <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                        <CheckBox x:Name="ExcludeHiddenBox" Content="排除隐藏" FontSize="12" Margin="0,0,12,6" Checked="Input_Changed" Unchecked="Input_Changed"/>
                        <CheckBox x:Name="ExcludeMissingBox" Content="排除缺失源目录" FontSize="12" IsChecked="True" Margin="0,0,12,6" Checked="Input_Changed" Unchecked="Input_Changed"/>
                        <CheckBox x:Name="ExcludeEmptyAuthorBox" Content="排除未指定作者" FontSize="12" Margin="0,0,12,6" Checked="Input_Changed" Unchecked="Input_Changed"/>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="36"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="目标根目录" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TargetRootBox" Style="{StaticResource AppDialogTextBox}" Height="36" TextChanged="Input_Changed"/>
                        <Button Grid.Column="1" Content="选择" Width="104" Height="36" Margin="8,0,0,0" Style="{StaticResource AppDialogGhostButton}" Click="BrowseTarget_Click"/>
                    </Grid>
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="目录模板" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Column="2" Text="冲突策略" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Column="4" Text="单本合集目录名" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Column="6" Text="少于几本归入合集" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                    </Grid>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <ComboBox x:Name="TemplateBox" Style="{StaticResource AppDialogComboBox}" Height="36" SelectionChanged="Input_Changed">
                                <ComboBoxItem Content="{}{作者}/{标题}"/>
                                <ComboBoxItem Content="{}{作者}/{年份} - {标题}"/>
                            </ComboBox>
                        </Grid>
                        <Grid Grid.Column="2">
                            <ComboBox x:Name="ConflictBox" Style="{StaticResource AppDialogComboBox}" Height="36" SelectionChanged="Input_Changed">
                                <ComboBoxItem Content="自动追加序号"/>
                                <ComboBoxItem Content="跳过冲突项"/>
                            </ComboBox>
                        </Grid>
                        <Grid Grid.Column="4">
                            <TextBox x:Name="EmptyAuthorBox" Text="单本合集" Style="{StaticResource AppDialogTextBox}" Height="36" TextChanged="Input_Changed"/>
                        </Grid>
                        <Grid Grid.Column="6">
                            <TextBox x:Name="SmallAuthorThresholdBox" Text="2" Style="{StaticResource AppDialogTextBox}" Height="36" TextChanged="Input_Changed"/>
                        </Grid>
                    </Grid>
                </Grid>

                <Border Grid.Column="4"
                        Padding="0"
                        Background="Transparent"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="BuildPlanButton" Content="生成预检" Height="36" Style="{StaticResource AppDialogButton}" Click="BuildPlan_Click"/>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock x:Name="PlanSummaryText"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                            <TextBlock x:Name="PendingRedirectText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource Brush.Accent}"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Height="32" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="预检风险"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="IssueFilterBox"
                                  Grid.Column="1"
                                  Width="112"
                                  Height="32"
                                  SelectionChanged="IssueFilterBox_SelectionChanged">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="只看错误"/>
                            <ComboBoxItem Content="只看警告"/>
                        </ComboBox>
                    </Grid>
                    <ListView x:Name="IssuesList" Grid.Row="1" Background="Transparent" BorderThickness="0" MouseDoubleClick="IssuesList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="级别" Width="58" DisplayMemberBinding="{Binding SeverityText}"/>
                                <GridViewColumn Header="类型" Width="82" DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="说明" Width="220" DisplayMemberBinding="{Binding Message}"/>
                                <GridViewColumn Header="作品" Width="118" DisplayMemberBinding="{Binding BookTitle}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Height="32" Margin="0,0,0,8">
                        <TextBlock Text="计划与执行结果"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <ProgressBar x:Name="ProgressBar" Height="8" Minimum="0" Maximum="1" Value="0"/>
                        <TextBlock x:Name="ProgressText" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ListView x:Name="ItemsList" Grid.Row="2" Background="Transparent" BorderThickness="0" MouseDoubleClick="ItemsList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="状态" Width="66" DisplayMemberBinding="{Binding StatusText}"/>
                                <GridViewColumn Header="作品" Width="220" DisplayMemberBinding="{Binding DisplayTitle}"/>
                                <GridViewColumn Header="文件" Width="58" DisplayMemberBinding="{Binding SourceFileCount}"/>
                                <GridViewColumn Header="大小" Width="76" DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="说明" Width="140" DisplayMemberBinding="{Binding Message}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenManifestButton" Content="打开 manifest" Click="OpenManifest_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="OpenTargetButton" Content="打开目标目录" Click="OpenTarget_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="PendingDetailsButton" Content="待重定向明细" Click="PendingDetails_Click" Style="{StaticResource AppDialogGhostButton}" Width="118" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="RedirectButton" Content="执行目录重定向" Click="Redirect_Click" Style="{StaticResource AppDialogGhostButton}" Width="126" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="StartButton" Content="开始安全导出" Click="Start_Click" Style="{StaticResource AppDialogButton}" Width="130" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="CancelRunButton" Content="取消执行" Click="CancelRun_Click" Style="{StaticResource AppDialogGhostButton}" Width="100" Margin="0,0,8,0" IsEnabled="False"/>
            <Button Content="关闭" Click="Close_Click" Style="{StaticResource AppDialogGhostButton}" Width="88"/>
        </StackPanel>
    </Grid>
</Window>
