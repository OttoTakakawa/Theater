<Window x:Class="MangaReader.Native.DataSafetyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据安全"
        Width="720"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="BackupListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Margin="0,0,0,8"
                                Padding="14,10"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="{DynamicResource Brush.SurfaceMuted}"
                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ScrollTrack}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <StackPanel>
                        <TextBlock Text="数据安全" Style="{StaticResource AppDialogTitleText}"/>
                        <TextBlock Text="管理数据库备份与恢复。漫画图片不会复制，真正需要保护的是 app.db。"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,20,0,16"
                        Padding="14"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.BorderSubtle}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="当前数据目录" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DataRootText"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock x:Name="BackupSummaryText"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontWeight="SemiBold"/>
                    </DockPanel>
                    <ListBox x:Name="BackupList"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource BackupListItemStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DetailText}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SizeText}"
                                               Margin="18,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextSubtle}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Row="3" Margin="0,22,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Content="立即备份" Click="CreateBackup_Click" Style="{StaticResource AppDialogButton}" Margin="0,0,8,0"/>
                        <Button DockPanel.Dock="Right" Content="恢复选中" Click="RestoreSelected_Click" Style="{StaticResource AppDialogDangerButton}"/>
                    </DockPanel>
                    <WrapPanel Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Right">
                        <Button Content="打开备份目录" Click="OpenBackupFolder_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="打开数据目录" Click="OpenDataFolder_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="选择其他 DB" Click="ChooseExternalDatabase_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="检查更新" Click="CheckUpdate_Click" Style="{StaticResource AppDialogGhostButton}"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
