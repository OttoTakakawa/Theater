<Window x:Class="MangaReader.Native.BatchPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量操作预览"
        Width="640"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText"
                   Text="批量操作预览"
                   FontSize="22"
                   FontWeight="Black"
                   Foreground="{DynamicResource Brush.TextPrimary}"
                   Margin="0,0,0,14"/>
        <Border Grid.Row="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.SurfaceMuted}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="14">
            <TextBox x:Name="PreviewTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     FontSize="13"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}" Width="96" Margin="0,0,10,0"/>
            <Button Content="执行" Click="Confirm_Click" Style="{StaticResource AppDialogButton}" Width="96"/>
        </StackPanel>
    </Grid>
</Window>
