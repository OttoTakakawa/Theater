<Window x:Class="MangaReader.Native.ImportFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加漫画"
        Width="620"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True"
                MouseLeftButtonDown="DialogRoot_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="添加漫画" Style="{StaticResource AppDialogTitleText}"/>
                        <TextBlock Text="拖入作者文件夹或单本漫画文件夹；也可以粘贴本地路径。" Style="{StaticResource AppDialogSubtitleText}"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1" Margin="0,24,0,0" Padding="22" CornerRadius="{StaticResource RadiusField}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="把文件夹拖到这里" FontSize="22" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="1"
                                   Text="支持多文件夹；会先判断单本、作者文件夹或混合结构。"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FolderPathBox" Style="{StaticResource AppDialogTextBox}" ToolTip="粘贴文件夹路径"/>
                    <Button Grid.Column="2" Content="加入路径" Click="AddPath_Click" Style="{StaticResource AppDialogGhostButton}"/>
                </Grid>

                <Border Grid.Row="3" Margin="0,18,0,0" Height="92" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Padding="10">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="FolderList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="12,8" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.SurfaceMuted}" BorderBrush="{DynamicResource Brush.ScrollTrack}" BorderThickness="1">
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="EmptyText"
                                   Text="尚未选择文件夹"
                                   Foreground="{DynamicResource Brush.TextSubtle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="4" Margin="0,20,0,0">
                    <TextBlock x:Name="HintText" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                        <Button Content="继续导入" Width="124" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
