<Window x:Class="MangaReader.Native.LibraryReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书库报告"
        Width="820"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText"
                   Text="书库报告"
                   FontSize="22"
                   FontWeight="Black"
                   Foreground="{DynamicResource Brush.TextPrimary}"
                   Margin="0,0,0,14"/>
        <Border Grid.Row="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.SurfaceMuted}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="14">
            <TextBox x:Name="ReportTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{DynamicResource Brush.TextPrimary}"
                     FontFamily="Consolas"
                     FontSize="13"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭" Click="Close_Click" Style="{StaticResource AppDialogButton}" Width="96"/>
        </StackPanel>
    </Grid>
</Window>
