<Window x:Class="Theater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Theater.Controls"
        xmlns:models="clr-namespace:Theater.Models"
        xmlns:local="clr-namespace:Theater"
        mc:Ignorable="d"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Title="Theater" Height="900" Width="1500" MinHeight="760" MinWidth="1180"
        Background="{DynamicResource Brush.AppBackground}" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:PathToFileNameConverter x:Key="PathToFileName"/>
        <DropShadowEffect x:Key="BookShadow" Color="{DynamicResource Color.TextPrimary}" BlurRadius="18" ShadowDepth="6" Opacity="0.14"/>
        <DropShadowEffect x:Key="PanelShadow" Color="{DynamicResource Color.TextPrimary}" BlurRadius="28" ShadowDepth="10" Opacity="0.08"/>

        <Style TargetType="Button" BasedOn="{StaticResource AppButton}"/>
        <Style x:Key="HomeWideBookCard" TargetType="Border">
            <Setter Property="Height" Value="208"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.SurfaceHover}"/>
                    <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
                    <Setter Property="Opacity" Value="0.96"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HomeCompactBookCard" TargetType="Border">
            <Setter Property="Width" Value="286"/>
            <Setter Property="Height" Value="104"/>
            <Setter Property="Margin" Value="0,0,14,12"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                    <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HomeBookActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="PrivacyCoverOverlay" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPrivacyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPrivacyCover}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FilterActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusField}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ScrollTrack}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TinyButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="LibraryPaginationToggleButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Black"/>
        </Style>
        <Style x:Key="DetailActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="DetailPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="DetailDangerActionButton" TargetType="Button" BasedOn="{StaticResource AppDangerButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="AppTagChipBorder" TargetType="Border" BasedOn="{StaticResource TagChipMd}"/>
        <Style x:Key="CardTagChipBorder" TargetType="Border" BasedOn="{StaticResource TagChipSm}"/>
        <Style x:Key="AppTagChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DetailHeroTagChipBorder" TargetType="Border" BasedOn="{StaticResource TagChipLg}"/>
        <Style x:Key="BatchActionButton" TargetType="Button" BasedOn="{StaticResource TinyButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>
        <Style x:Key="BatchDangerActionButton" TargetType="Button" BasedOn="{StaticResource AppDangerButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Track" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource RadiusProgress}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="13,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusField}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Dim}"/>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Surface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="16,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Grid Grid.Column="1">
                                        <Path Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{DynamicResource Brush.TextMuted}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,6,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.BorderStrong}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusField}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280"
                                                  CanContentScroll="True">
                                        <ItemsPresenter Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Brush.Dim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FilterComboBox_PreviewMouseLeftButtonDown"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Border Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            Background="{DynamicResource Brush.ScrollTrack}"
                                            CornerRadius="{StaticResource RadiusControl}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <Path Data="M 0 0 L 5 5 L 10 0"
                                              Stroke="{DynamicResource Brush.TextMuted}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,8,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280" CanContentScroll="True" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter Margin="6"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Brush.Dim}"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Brush.Surface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusPanel}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.ScrollTrack}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.BorderSubtle}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.BorderStrong}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CheckRoot"
                                MinHeight="36"
                                Padding="12,7"
                                Background="{DynamicResource Brush.SurfaceMuted}"
                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusControl}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="CheckMark"
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.ScrollThumb}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusClip}">
                                    <Path x:Name="CheckGlyph"
                                          Data="M 4 9 L 7 12 L 14 5"
                                          Stroke="{DynamicResource Brush.Surface}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckRoot" Property="Background" Value="{DynamicResource Brush.ScrollTrack}"/>
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Background" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BatchSelectCheckBox" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SelectRoot"
                                Width="22"
                                Height="22"
                                Background="{DynamicResource Brush.SurfaceMuted}"
                                BorderBrush="{DynamicResource Brush.ScrollThumb}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Path x:Name="SelectGlyph"
                                  Data="M 4 8 L 7 11 L 12 5"
                                  Stroke="{DynamicResource Brush.Surface}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="{DynamicResource Brush.ScrollTrack}"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="{DynamicResource Brush.ScrollThumbHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter TargetName="SelectGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="SidebarNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="132"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
        </Style>
        <Style x:Key="SidebarToggleButton" TargetType="Button" BasedOn="{StaticResource SidebarActionButton}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="Background" Value="{DynamicResource Brush.TextPrimary}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Surface}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarCollapseButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
        </Style>
        <Style x:Key="SidebarExpandButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}"/>
        </Style>
        <Style x:Key="SidebarLogToggleButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}"/>
        </Style>
        <Style x:Key="LibraryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionFrame" Padding="4" Background="{DynamicResource Brush.SurfaceMuted}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource RadiusPanel}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="{DynamicResource Brush.SurfaceSelected}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectionFrame" Property="Background" Value="{DynamicResource Brush.SurfaceSelected}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="LibraryBookTemplate">
            <Border x:Name="LibraryBookCard"
                    Width="{Binding BookWidth}"
                    Height="{Binding BookHeight}"
                    Padding="12"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    MouseEnter="BookCard_MouseEnter"
                    MouseLeave="BookCard_MouseLeave"
                    PreviewMouseLeftButtonDown="BookCard_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="BookCard_PreviewMouseLeftButtonUp"
                    PreviewMouseRightButtonDown="BookCard_PreviewMouseRightButtonDown"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelectedForBatch}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSelected}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel>
                    <!-- 视频封面 16:9 -->
                    <Grid Width="{Binding CoverWidth}" Height="{Binding CoverHeight}" HorizontalAlignment="Center"
                          Visibility="{Binding VideoCardVisibility}">
                        <Border CornerRadius="{StaticResource RadiusPanel}" ClipToBounds="True" Background="#111827"
                                Effect="{StaticResource BookShadow}">
                            <Grid>
                                <Image Source="{Binding CoverImage}" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- 底部渐变覆盖 -->
                                <Rectangle>
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#B8111827" Offset="0"/>
                                            <GradientStop Color="#00111827" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <!-- 播放按钮 -->
                                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Width="42" Height="42" CornerRadius="{StaticResource RadiusPanel}"
                                        Background="#C8111827" BorderBrush="#55FFFFFF" BorderThickness="1">
                                    <Path Width="13" Height="16" Stretch="Fill" Fill="#F8FAFC"
                                          Data="M 0 0 L 13 8 L 0 16 Z"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </Border>
                            </Grid>
                        </Border>
                        <CheckBox IsChecked="{Binding IsSelectedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource BatchSelectCheckBox}"
                                  Visibility="{Binding IsBatchSelectionUiVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                  Checked="BatchSelection_Changed"
                                  Unchecked="BatchSelection_Changed"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="6,6,0,0"/>
                    </Grid>

                    <Grid Width="162" Height="220" HorizontalAlignment="Center"
                          Visibility="{Binding MangaCardVisibility, FallbackValue=Visible}">
                        <Grid Width="150" Height="214" VerticalAlignment="Top" Effect="{StaticResource BookShadow}">
                            <Grid x:Name="BoundMangaCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Border Width="42" HorizontalAlignment="Left" CornerRadius="{StaticResource RadiusClipLeft}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#70000000" Offset="0"/>
                                            <GradientStop Color="#26000000" Offset="0.48"/>
                                            <GradientStop Color="#24FFFFFF" Offset="0.66"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Rectangle Width="12" HorizontalAlignment="Left" Margin="27,5,0,5" RadiusX="6" RadiusY="6" Opacity="0.38">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#55FFFFFF" Offset="0.55"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>

                            <Grid x:Name="PlainCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                            </Grid>

                            <Grid x:Name="WhiteBorderCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="2">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="{StaticResource RadiusProgress}" Padding="7">
                                    <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                </Border>
                            </Grid>
                            <Border Style="{StaticResource PrivacyCoverOverlay}"
                                    CornerRadius="{StaticResource RadiusProgress}">
                                <TextBlock Text="隐私模式"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.BorderSubtle}"
                                           FontSize="13"
                                           FontWeight="Black"/>
                            </Border>
                        </Grid>
                        <Border Padding="7,3"
                                CornerRadius="{StaticResource RadiusControl}"
                                BorderThickness="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,2,0">
                            <ContentControl ContentTemplate="{StaticResource RatingBadgeTemplate}" Content="{Binding}"/>
                        </Border>
                        <CheckBox IsChecked="{Binding IsSelectedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource BatchSelectCheckBox}"
                                  Visibility="{Binding IsBatchSelectionUiVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                  Checked="BatchSelection_Changed"
                                  Unchecked="BatchSelection_Changed"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="6,6,0,0"/>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Black" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <!-- 视频缺失标签行 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,0">
                            <!-- 视频缺失标签 -->
                            <Border Padding="6,2" CornerRadius="{StaticResource RadiusControl}"
                                    Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVideo}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="视频不见了" FontSize="10" FontWeight="Bold" Foreground="#C2410C"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding LibraryMetaText}" Margin="0,5,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding LibraryMetaSubText}" Foreground="{DynamicResource Brush.Accent}" FontSize="11" TextAlignment="Center" TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,4,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding MissingText}" Foreground="{DynamicResource Brush.StatusMissing}" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding HiddenText}" Foreground="{DynamicResource Brush.StatusHidden}" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding CardTagItems}" Margin="0,8,0,0" MaxHeight="44" ClipToBounds="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardTagChipBorder}"
                                            MaxWidth="170"
                                            Background="{Binding Color}"
                                            MouseEnter="TagChip_MouseEnter"
                                            MouseLeave="TagChip_MouseLeave"
                                            PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                                            MouseMove="TagChip_MouseMove"
                                            MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                                        <TextBlock Text="{Binding Name}"
                                                   MaxWidth="148"
                                                   Style="{StaticResource AppTagChipText}"
                                                   FontSize="10"
                                                   LineHeight="12"
                                                   LineStackingStrategy="BlockLineHeight"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeWideBookTemplate">
            <Border Style="{StaticResource HomeWideBookCard}"
                    MouseLeftButtonDown="HomeBook_Click"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource Color.TextPrimary}" Offset="0"/>
                            <GradientStop Color="{DynamicResource Color.TextPrimary}" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid>
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill" Opacity="0.34"/>
                        <Border Style="{StaticResource PrivacyCoverOverlay}"/>
                    </Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource Color.TextPrimary}" Offset="0"/>
                                <GradientStop Color="{DynamicResource Color.TextPrimary}" Offset="0.52"/>
                                <GradientStop Color="{DynamicResource Color.TextPrimary}" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="92" Height="138" CornerRadius="{StaticResource RadiusPanel}" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center" Effect="{StaticResource BookShadow}">
                            <Grid>
                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                <Border Style="{StaticResource PrivacyCoverOverlay}"
                                        CornerRadius="{StaticResource RadiusPanel}"/>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="1" Margin="12,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding ContinueActionText}" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="0,10,0,0" Foreground="{DynamicResource Brush.Surface}" FontSize="22" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="2" Text="{Binding Author}" Margin="0,7,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                <TextBlock Text="{Binding ReadingMetaText}" Foreground="{DynamicResource Brush.TextMuted}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding LibraryMetaText}" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Row="4"
                                    Content="查看详情"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource HomeBookActionButton}"
                                    Click="HomeBookButton_Click"/>
                        </Grid>
                    </Grid>
                    <Border Padding="9,5"
                            CornerRadius="{StaticResource RadiusControl}"
                            Background="{DynamicResource Brush.Favorite}"
                            BorderBrush="{DynamicResource Brush.Favorite}"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,14,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="★" Foreground="{DynamicResource Brush.Accent}" FontSize="14"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeCompactBookTemplate">
            <Border Style="{StaticResource HomeCompactBookCard}"
                    MouseLeftButtonDown="HomeBook_Click"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="68" Height="84" CornerRadius="{StaticResource RadiusPanel}" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                            <Border Style="{StaticResource PrivacyCoverOverlay}"
                                    CornerRadius="{StaticResource RadiusPanel}"/>
                        </Grid>
                    </Border>
                    <Border Grid.ColumnSpan="2"
                            Padding="7,3"
                            CornerRadius="{StaticResource RadiusControl}"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,0,0">
                        <ContentControl ContentTemplate="{StaticResource RatingBadgeTemplate}" Content="{Binding}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,4,56,0">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ReadingMetaText}" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LibraryMetaText}" Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TagChipItemTemplate" DataType="{x:Type models:TagChip}">
            <Border Margin="3"
                    Padding="10,6"
                    Background="{Binding Color}"
                    MouseEnter="TagChip_MouseEnter"
                    MouseLeave="TagChip_MouseLeave"
                    PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                    MouseMove="TagChip_MouseMove"
                    MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                        <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                        <Separator/>
                        <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource AppTagChipBorder}">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.38"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Category}" FontSize="11" Margin="0,0,5,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppTagChipText}">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Name}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppTagChipText}">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding UsageCount, StringFormat='({0})'}"
                               FontSize="10"
                               Margin="3,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TagPoolChipTemplate" DataType="{x:Type models:TagChip}">
            <Border Margin="3" Padding="10,6" Background="{Binding Color}"
                    MouseEnter="TagChip_MouseEnter" MouseLeave="TagChip_MouseLeave"
                    PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                    MouseMove="TagChip_MouseMove" MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="筛选此标签" Click="TagContextFilter_Click"/>
                        <MenuItem Header="排除此标签" Click="TagContextExclude_Click"/>
                        <Separator/>
                        <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                        <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                        <Separator/>
                        <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource AppTagChipBorder}">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.38"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.38"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppTagChipText}">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding UsageCount}"
                               FontSize="10"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource Color.SurfaceMuted}" Offset="0"/>
                <GradientStop Color="{DynamicResource Color.ScrollTrack}" Offset="0.55"/>
                <GradientStop Color="{DynamicResource Color.ScrollTrack}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="228"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DetailColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border x:Name="SidebarExpandedPanel" Margin="18" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid Margin="0,4,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="46" Height="46" CornerRadius="{StaticResource RadiusControl}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="pack://application:,,,/Assets/icon.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="12,2,0,0">
                                        <TextBlock Text="Theater" FontSize="21" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                        <TextBlock x:Name="VersionText" FontSize="11" Foreground="{DynamicResource Brush.Dim}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,18">
                                <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                    <TextBlock Text="浏览"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                                <Button x:Name="HomeNavButton" Content="主页" Click="NavHome_Click" Style="{StaticResource SidebarNavButton}"/>
                                <Button x:Name="LibraryNavButton" Content="视频库" Click="NavLibrary_Click" Style="{StaticResource SidebarNavButton}"/>
                                <Button x:Name="TagsNavButton" Content="标签" Click="NavTags_Click" Style="{StaticResource SidebarNavButton}"/>
                                <Button x:Name="AuthorsNavButton" Content="作者" Click="NavAuthors_Click" Style="{StaticResource SidebarNavButton}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,18">
                                <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                    <TextBlock Text="工具"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                                <StackPanel Width="132" HorizontalAlignment="Center">
                                    <Button Content="设置" Click="Settings_Click" Style="{StaticResource SidebarActionButton}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                    <TextBlock Text="调试"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                                <StackPanel Width="132" HorizontalAlignment="Center">
                                    <Button Content="检查更新" Click="CheckUpdate_Click" Style="{StaticResource SidebarActionButton}"/>
                                    <Button x:Name="LogPanelToggleButton"
                                            Content="展开日志"
                                            Click="ToggleStatusPanel_Click"
                                            Style="{StaticResource SidebarToggleButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="1"
                            Margin="0,14,0,-2"
                            Padding="0"
                            Background="Transparent">
                        <Button x:Name="SidebarCollapseButton"
                                Content="◀"
                                Click="ToggleSidebarCollapse_Click"
                                Style="{StaticResource SidebarCollapseButton}"
                                HorizontalAlignment="Center"
                                ToolTip="收起导航栏"/>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="SidebarCollapsedPanel"
                    Margin="18"
                    Padding="0"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Effect="{StaticResource PanelShadow}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="1"
                            Margin="0,0,0,14"
                            Padding="0"
                            Background="Transparent">
                        <Button x:Name="SidebarExpandButton"
                                Content="☰"
                                Click="ToggleSidebarCollapse_Click"
                                Style="{StaticResource SidebarExpandButton}"
                                HorizontalAlignment="Center"
                                ToolTip="展开导航栏"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,26,0,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="HomePagePanel">
                <ScrollViewer x:Name="HomeMainScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                    <StackPanel Margin="8,0,22,12">
                        <Border x:Name="HomeEmptyState" Padding="26" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Effect="{StaticResource PanelShadow}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="先导入一部作品" FontSize="30" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                    <TextBlock x:Name="HomeIntroText" Text="首页只有在有内容时才应该存在。现在先导入一部作品，后面才会出现继续观看、收藏和最近加入。" Margin="0,10,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="15" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="导入作品" Click="ChooseLibrary_Click" Margin="0,0,10,0"/>
                                    <Button Content="去书库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="HomeSectionsPanel">
                        <Border Padding="18"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                BorderThickness="1"
                                Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <TextBlock Text="继续观看" Margin="4,0,0,14" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <ItemsControl ItemsSource="{Binding ContinueReadingBooks}" ItemTemplate="{StaticResource HomeWideBookTemplate}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock x:Name="ContinueReadingEmptyText" Text="还没有可继续观看的作品，先打开一部，主页就会把它放在这里。" Margin="4,10,0,0" Foreground="{DynamicResource Brush.TextMuted}" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <DockPanel Margin="4,28,0,14">
                            <Button DockPanel.Dock="Right" Content="换一批" Click="RefreshRecentReading_Click" Style="{StaticResource AppGhostButton}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="之前看过" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                             <ItemsControl ItemsSource="{Binding RecentReadingBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentReadingEmptyText" Text="还没有观看记录，看过的作品会出现在这里。" Margin="4,10,0,0" Foreground="{DynamicResource Brush.TextMuted}" Visibility="Collapsed"/>

                        <DockPanel Margin="4,28,0,14">
                            <Button DockPanel.Dock="Right" Content="换一批" Click="RefreshFavorites_Click" Style="{StaticResource AppGhostButton}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="收藏" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FavoriteShowcaseBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="FavoriteShowcaseEmptyText" Text="还没有收藏作品，先在库里挑几部真正想反复回看的。" Margin="4,10,0,0" Foreground="{DynamicResource Brush.TextMuted}" Visibility="Collapsed"/>

                        <TextBlock Text="最近加入" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PreviewMouseWheel="HorizontalShelfScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding RecentlyAddedBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentlyAddedEmptyText" Text="这里还没有新加入的作品，导入后会自动出现。" Margin="4,10,0,0" Foreground="{DynamicResource Brush.TextMuted}" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="LibraryPagePanel"
                  Visibility="Collapsed"
                  Background="Transparent"
                  MouseDown="LibraryArea_MouseDown"
                  AllowDrop="True"
                  DragEnter="LibraryPagePanel_DragEnter"
                  DragOver="LibraryPagePanel_DragOver"
                  DragLeave="LibraryPagePanel_DragLeave"
                  Drop="LibraryPagePanel_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="LibraryFilterPanel" Grid.Row="0" Margin="8,0,22,10" Padding="10" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FilterSummaryText" Text="当前显示全部作品" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Accent}" FontSize="12" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel x:Name="LibraryMetricPanel" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当前" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="VisibleBookCountText" Text="0 本" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Black"/>
                                            <TextBlock x:Name="TotalBookCountText" Text=" / 共 0 本" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="收藏" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="FavoriteCountText" Text="0 本" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="在看" Foreground="{DynamicResource Brush.StatusReading}" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="ReadingNowCountText" Text="0 部" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="看过" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="ReadCountBookText" Text="0 部" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="LibraryFilterToggleButton" Content="收起排序" Click="ToggleLibraryFilter_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                <Button x:Name="LibraryChromeToggleButton" Content="收起标签筛选" Click="ToggleLibraryChrome_Click" Style="{StaticResource AppGhostButton}"/>
                            </StackPanel>
                        </Grid>
                        <WrapPanel x:Name="LibraryFilterControlsPanel" Grid.Row="1" VerticalAlignment="Center" ItemHeight="36">
                            <TextBox x:Name="BookSearchBox" Width="280" Height="36" MinHeight="36" Padding="14,4" Margin="0,0,10,0" TextChanged="BookSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索标题、作者、标签"/>
                            <ComboBox x:Name="AuthorFilterBox" Width="156" Height="36" MinHeight="36" Padding="14,4" Margin="0,0,10,0" ItemsSource="{Binding AuthorFilters}" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip="{Binding}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox x:Name="StatusFilterBox" Width="148" Height="36" MinHeight="36" Padding="14,4" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="状态：全部"/>
                                <ComboBoxItem Content="状态：未看"/>
                                <ComboBoxItem Content="状态：在看"/>
                            </ComboBox>
                            <ComboBox x:Name="SortBox" Width="174" Height="36" MinHeight="36" Padding="14,4" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="SortBox_SelectionChanged" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="排序：标题"/>
                                <ComboBoxItem Content="排序：评分"/>
                                <ComboBoxItem Content="排序：页数"/>
                                <ComboBoxItem Content="排序：容量"/>
                                <ComboBoxItem Content="排序：观看次数"/>
                                <ComboBoxItem Content="排序：录入时间"/>
                                <ComboBoxItem Content="排序：出品时间"/>
                            </ComboBox>
                            <Button x:Name="SortDirectionButton" Content="升序" Click="ToggleSortDirection_Click" Style="{StaticResource FilterActionButton}" Height="36" MinHeight="36" Padding="14,6" Margin="0,0,10,0"/>
                            <Button x:Name="BatchModeToggleButton" Content="多选管理" Click="ToggleBatchSelectionMode_Click" Style="{StaticResource FilterActionButton}" Height="36" MinHeight="36" Padding="14,6" Margin="0,0,10,0"/>
                            <Button x:Name="ClearFiltersButton" Content="清空筛选" Click="ClearFilters_Click" Style="{StaticResource FilterActionButton}" Height="36" MinHeight="36" Padding="14,6"/>
                        </WrapPanel>
                        <Border x:Name="BatchManageShell" Grid.Row="2" Margin="0,10,0,0" Padding="8" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.ScrollTrack}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Visibility="Collapsed">
                            <WrapPanel x:Name="BatchManagePanel" VerticalAlignment="Center" ItemHeight="32">
                                <Border Padding="10,5" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Margin="0,0,6,0">
                                    <TextBlock x:Name="BatchSelectionText" Text="0 本" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="12" FontWeight="Black" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="选中当前页" Click="SelectVisibleBooks_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="清空" Click="ClearBatchSelection_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <TextBlock Text="框选追加，Ctrl 框选减选" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Content="重命名" Click="BatchRemoveTitlePrefix_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <ComboBox x:Name="BatchStyleBox" Width="140" Height="32" MinHeight="32" Padding="10,4" SelectedIndex="0" Style="{StaticResource FilterComboBox}" Margin="0,0,6,0">
                                    <ComboBoxItem Content="书脊卡片"/>
                                    <ComboBoxItem Content="纯图卡片"/>
                                    <ComboBoxItem Content="圆角卡片"/>
                                </ComboBox>
                                <Button Content="应用" Click="BatchApplyStyle_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="+ Tag" Click="BatchAddTag_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="- Tag" Click="BatchRemoveTag_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="删库记录" Click="BatchDeleteRecords_Click" Style="{StaticResource BatchDangerActionButton}" Margin="0,0,6,0"/>
                                <Button Content="删源文件" Click="BatchDeleteSourceFiles_Click" Style="{StaticResource BatchDangerActionButton}"/>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="LibraryTagPanel" Grid.Row="1" Margin="8,0,22,10" Padding="10" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,7">
                            <Button x:Name="ToggleAllTagGroupsButton" DockPanel.Dock="Right" Content="全折叠" Click="ToggleAllTagGroups_Click" Style="{StaticResource FilterActionButton}" Height="36" MinHeight="36" Padding="14,6" Margin="8,0,0,0" ToolTip="折叠/展开所有标签分类"/>
                            <ComboBox x:Name="TagGroupSortBox" DockPanel.Dock="Right" Width="160" Height="36" MinHeight="36" Padding="14,4" SelectedIndex="1" SelectionChanged="TagGroupSortBox_SelectionChanged" Style="{StaticResource FilterComboBox}" ToolTip="标签分类排序方式" Margin="8,0,0,0">
                                <ComboBoxItem Content="按分类顺序"/>
                                <ComboBoxItem Content="按标签数量"/>
                                <ComboBoxItem Content="按作品数量"/>
                                <ComboBoxItem Content="按名称"/>
                            </ComboBox>
                            <Button DockPanel.Dock="Right" Content="添加" Click="AddTag_Click" Style="{StaticResource FilterActionButton}" Margin="8,0,0,0" Height="36" MinHeight="36" Padding="14,6"/>
                            <TextBox x:Name="TagSearchBox" DockPanel.Dock="Right" Width="280" TextChanged="TagSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" Height="36" MinHeight="36" Padding="14,4" Margin="8,0,0,0" ToolTip="搜索 Tag；点添加可创建候选 Tag，选中作品时会直接添加到作品"/>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox x:Name="FavoriteOnlyBox" Content="只看收藏" Margin="0,0,6,0" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
                                <CheckBox x:Name="OnlyHiddenBox" Content="只看隐藏作品" Margin="0,0,10,0" Checked="OnlyHidden_Changed" Unchecked="OnlyHidden_Changed"/>
                                <TextBlock x:Name="ActiveTagSummaryText" Text="已选 0 个 Tag" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl x:Name="ActiveTagFilterList" ItemsSource="{Binding ActiveTagFilters}" Visibility="Collapsed" Margin="0,0,0,7">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TagChip}">
                                    <Border Margin="0,0,6,6"
                                            Padding="9,4"
                                            Background="{Binding Color}"
                                            BorderBrush="{DynamicResource Brush.TextPrimary}"
                                            MouseLeftButtonDown="ActiveTagChip_Click">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource AppTagChipBorder}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                            <TextBlock Text=" ×" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="168" PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                            <ItemsControl x:Name="TagPool" ItemsSource="{Binding VisibleTagGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TagCategoryGroup}">
                                        <Grid Margin="0,0,6,1" Width="260">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border x:Name="TagGroupHeader" Grid.Row="0" Padding="0,0,0,0" Background="Transparent">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleButton Grid.Column="0"
                                                                  HorizontalAlignment="Left"
                                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                  Style="{StaticResource TagCategoryHeaderToggleButton}"
                                                                  ToolTip="点击折叠/展开该分类">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Arrow}" Margin="0,0,6,0" FontSize="11" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Header}"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Button Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Width="20"
                                                            Height="20"
                                                            Padding="0"
                                                            Margin="2,0,0,0"
                                                            Click="AddTagToCategory_Click"
                                                            Tag="{Binding Category}"
                                                            ToolTip="在此分类下添加新 Tag"
                                                            Opacity="0.35">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Grid Width="20" Height="20" Background="Transparent">
                                                                    <Ellipse x:Name="BtnBorder"
                                                                             Width="20"
                                                                             Height="20"
                                                                             Stroke="{DynamicResource Brush.TextMuted}"
                                                                             StrokeThickness="1"
                                                                             StrokeDashArray="3,2"
                                                                             Fill="Transparent"
                                                                             SnapsToDevicePixels="True"/>
                                                                    <TextBlock Text="+"
                                                                               FontSize="12"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,-1,0,0"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="BtnBorder" Property="Stroke" Value="{DynamicResource Brush.Accent}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                            <ScrollViewer Grid.Row="1"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto"
                                                          MaxHeight="84"
                                                          Visibility="{Binding TagsVisibility}"
                                                          PreviewMouseWheel="TagGroupScrollViewer_PreviewMouseWheel">
                                                <ItemsControl ItemsSource="{Binding Tags}"
                                                              ItemTemplate="{StaticResource TagPoolChipTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="BooksList"
                             Grid.Row="0"
                             ItemsSource="{Binding Books}"
                             ItemContainerStyle="{StaticResource LibraryListItemStyle}"
                             ItemTemplate="{StaticResource LibraryBookTemplate}"
                             Margin="8,4,56,4"
                             SelectionChanged="BooksList_SelectionChanged"
                             MouseDoubleClick="BooksList_MouseDoubleClick"
                             PreviewMouseLeftButtonDown="BooksList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="BooksList_PreviewMouseMove"
                             PreviewMouseLeftButtonUp="BooksList_PreviewMouseLeftButtonUp"
                             AllowDrop="True"
                             DragEnter="LibraryPagePanel_DragEnter"
                             DragOver="LibraryPagePanel_DragOver"
                             DragLeave="LibraryPagePanel_DragLeave"
                             Drop="BooksList_Drop"
                             PreviewMouseWheel="FastItemsScrollViewer_PreviewMouseWheel"
                             Background="Transparent"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.CacheLength="4"
                             VirtualizingPanel.CacheLengthUnit="Page"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel ItemWidth="354"
                                                                ItemHeight="380"
                                                                HorizontalSpacing="16"
                                                                VerticalSpacing="14"
                                                                OverscanRows="2"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                    <Canvas x:Name="RubberBandLayer" Grid.Row="0" IsHitTestVisible="False" Margin="8,4,56,4">
                        <Rectangle x:Name="RubberBandRect"
                                   Stroke="{DynamicResource Brush.BorderStrong}"
                                   StrokeThickness="1"
                                   StrokeDashArray="3,2"
                                   Fill="#10000000"
                                   RadiusX="3"
                                   RadiusY="3"
                                   Visibility="Collapsed"/>
                    </Canvas>
                    <Border x:Name="ShelfEmptyState" Grid.Row="0" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                        <StackPanel Width="320">
                            <TextBlock Text="当前列表是空的" FontSize="26" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}" TextAlignment="Center"/>
                            <TextBlock x:Name="ShelfEmptyHintText" Text="可以先清空筛选，或者导入新的文件夹。" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{DynamicResource Brush.TextMuted}" TextAlignment="Center" LineHeight="22"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="LibraryPaginationToggle" Grid.Row="0" Content="▼" Click="ToggleLibraryPagination_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource LibraryPaginationToggleButton}" Margin="0,0,8,8" Panel.ZIndex="10" ToolTip="折叠分页栏" Visibility="Collapsed"/>
                </Grid>

                <Border x:Name="LibraryPaginationBar" Grid.Row="3" Padding="12,8" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="0,1,0,0" CornerRadius="0" Visibility="Collapsed">
                    <Grid>
                        <WrapPanel x:Name="LibraryPaginationPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="LibraryPageText" Text="第 0 / 1 页 · 本页 0 本 · 筛选结果 0 本" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button x:Name="LibraryFirstPageButton" Content="首页" Click="LibraryFirstPage_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,4,0"/>
                            <Button x:Name="LibraryPreviousPageButton" Content="上一页" Click="LibraryPreviousPage_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,4,0"/>
                            <Button x:Name="LibraryNextPageButton" Content="下一页" Click="LibraryNextPage_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,4,0"/>
                            <Button x:Name="LibraryLastPageButton" Content="末页" Click="LibraryLastPage_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,12,0"/>
                            <TextBlock Text="每页行数" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="LibraryPageSizeBox" Width="130" Height="34" SelectedIndex="1" SelectionChanged="LibraryPageSizeBox_SelectionChanged" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="10 行" Tag="70"/>
                                <ComboBoxItem Content="20 行" Tag="140"/>
                                <ComboBoxItem Content="50 行" Tag="350"/>
                            </ComboBox>
                        </WrapPanel>
                    </Grid>
                </Border>
                <Border x:Name="LibraryLoadProgressPanel"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="True"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.BorderSubtle}"
                        BorderThickness="1"
                        Panel.ZIndex="34">
                    <Border Width="520"
                            Padding="28"
                            CornerRadius="{StaticResource RadiusPanel}"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.BorderSubtle}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Effect="{StaticResource PanelShadow}">
                        <StackPanel>
                            <TextBlock x:Name="LibraryLoadProgressTitle"
                                       Text="正在加载书库"
                                       FontSize="26"
                                       FontWeight="Black"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       MaxWidth="600"/>
                            <ProgressBar x:Name="LibraryLoadProgressBar"
                                         Style="{StaticResource SlimProgressBar}"
                                         Margin="0,18,0,0"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"/>
                            <TextBlock x:Name="LibraryLoadProgressText"
                                       Text="准备扫描..."
                                       Margin="0,14,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <Button Content="取消扫描"
                                    Width="112"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Center"
                                    Click="CancelLibraryScan_Click"
                                    Style="{StaticResource AppDialogGhostButton}"/>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="ImportProgressPanel"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="True"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.BorderSubtle}"
                        BorderThickness="1"
                        Panel.ZIndex="35">
                    <Border Width="520"
                            Padding="28"
                            CornerRadius="{StaticResource RadiusPanel}"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.BorderSubtle}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Effect="{StaticResource PanelShadow}">
                        <StackPanel>
                            <TextBlock x:Name="ImportProgressTitle"
                                       Text="正在导入"
                                       FontSize="26"
                                       FontWeight="Black"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       TextAlignment="Center"/>
                            <ProgressBar x:Name="ImportProgressBar"
                                         Style="{StaticResource SlimProgressBar}"
                                         Margin="0,18,0,0"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"/>
                            <TextBlock x:Name="ImportProgressText"
                                       Text="准备中..."
                                       Margin="0,14,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <Button Content="取消导入"
                                    Width="112"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Center"
                                    Click="CancelImport_Click"
                                    Style="{StaticResource AppDialogGhostButton}"/>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="ImportDropOverlay"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="{DynamicResource Brush.TextPrimary}"
                        BorderBrush="{DynamicResource Brush.StatusReading}"
                        BorderThickness="2"
                        Panel.ZIndex="40">
                    <Grid>
                        <Border Width="520"
                                Padding="34"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.StatusReading}"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock x:Name="ImportDropTitle"
                                           Text="松开以导入文件夹"
                                           FontSize="30"
                                           FontWeight="Black"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="ImportDropHint"
                                           Text="会按作者文件夹识别子目录，并在导入前弹出确认列表。"
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TagsPagePanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="8,0,22,0">
                        <Border Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="标签管理" FontSize="30" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="去书库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="8,16,22,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="全部标签" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerTotalCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                    <TextBlock Text="包含内置和用户标签" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="正在使用" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerUsedCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                    <TextBlock Text="至少关联 1 部作品" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="候选标签" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerStandaloneCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                    <TextBlock Text="未关联时只能作为待分配标签" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="标签组" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerGroupCountText" Text="0 组" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                    <TextBlock Text="按分组统一颜色" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </Border>
                </Grid>

                <Border Grid.Row="2" Margin="8,0,22,12" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="新建候选标签" Click="CreateManagedTag_Click" Style="{StaticResource HeaderActionButton}" Margin="10,2,0,2"/>
                            <ComboBox x:Name="TagSortBox" DockPanel.Dock="Right" Width="130" Height="44" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="TagManagerFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="按组排序"/>
                                <ComboBoxItem Content="按使用量"/>
                                <ComboBoxItem Content="按名称"/>
                            </ComboBox>
                            <ComboBox x:Name="TagGroupFilterBox" DockPanel.Dock="Right" Width="130" Height="44" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="TagManagerFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="全部分组"/>
                            </ComboBox>
                            <TextBox x:Name="TagManagerSearchBox" Height="44" TextChanged="TagManagerSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索标签"/>
                        </DockPanel>
                        <ListBox Grid.Row="1" x:Name="TagManagerList" ItemsSource="{Binding TagManagerItems}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TagChip}">
                                    <Border Margin="0,0,0,10" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" HorizontalAlignment="Stretch">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="按此标签筛选" Click="TagManagerFilter_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="按此标签筛选" Click="TagManagerFilter_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="编辑标签" Click="RenameTagButton_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="删除" Click="DeleteTagButton_Click" Style="{StaticResource AppDangerButton}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding Color}" CornerRadius="{StaticResource RadiusControl}" Padding="10,5" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Category}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                </StackPanel>
                                                <WrapPanel Margin="0,8,0,0"
                                                           Cursor="Hand"
                                                           ToolTip="点击查看关联作品"
                                                           MouseLeftButtonDown="TagUsage_MouseLeftButtonDown">
                                                    <TextBlock Text="已关联 " Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text="{Binding UsageCount}" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text=" 部作品" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text=" · " Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text="{Binding SourceText}" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text=" · " Foreground="{DynamicResource Brush.TextMuted}"/>
                                                    <TextBlock Text="{Binding TypeText, Mode=OneWay}" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" x:Name="TagManagerEmptyState" Visibility="Collapsed" Margin="0,4,0,0" Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.SurfaceMuted}">
                            <TextBlock Text="当前没有命中的标签，可以换个关键词，或者新建一个新的标签。"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="AuthorsPagePanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="8,0,22,0">
                        <Border Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="作者管理" FontSize="30" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="新增作者" Click="CreateAuthor_Click" Style="{StaticResource HeaderActionButton}" Margin="0,0,10,0"/>
                                    <Button Content="去书库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="8,16,22,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="全部作者" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AuthorTotalText" Text="0 位" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <TextBlock Text="去重计数" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="关联书籍" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AuthorBookTotalText" Text="0 本" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <TextBlock Text="已指定作者的作品" Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Margin="8,0,22,12" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="AuthorSearchBox" Height="44" Margin="0,0,0,12" TextChanged="AuthorSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索作者名"/>
                        <ListBox Grid.Row="1" x:Name="AuthorManagerList" ItemsSource="{Binding AuthorManagerItems}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AuthorItem}">
                                    <Border Margin="0,0,0,6" Padding="14,10" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" HorizontalAlignment="Stretch">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="按照此作者筛选" Click="FilterByAuthor_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="修改作者信息" Click="RenameAuthor_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="删除" Click="DeleteAuthor_Click" Style="{StaticResource AppDangerButton}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                <TextBlock Text="{Binding BookCount, StringFormat={}{0} 本书籍}" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" x:Name="AuthorManagerEmptyState" Visibility="Collapsed" Margin="0,4,0,0" Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.SurfaceMuted}">
                            <TextBlock Text="没有匹配的作者。"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="LogPanel"
                    Grid.Row="1"
                    Height="160"
                    Margin="8,14,22,0"
                    Padding="0"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.TextPrimary}"
                    BorderBrush="{DynamicResource Brush.TextPrimary}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="输出"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.SurfaceMuted}"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="1"
                                   Text="实时状态 / app 日志"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="12"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="LogPanelExpandButton" Content="扩大" Click="ToggleLogPanelSize_Click" Style="{StaticResource TinyButton}" Margin="0,0,10,0"/>
                            <Button Content="复制全部" Click="CopyLogOutput_Click" Style="{StaticResource TinyButton}" Margin="0,0,10,0"/>
                            <Button Content="清空" Click="ClearLogOutput_Click" Style="{StaticResource TinyButton}" Margin="0,0,10,0"/>
                            <Button Content="打开日志目录" Click="OpenLogFolder_Click" Style="{StaticResource TinyButton}"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Margin="12,0" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.TextPrimary}">
                        <ScrollViewer x:Name="LogOutputScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="14,12">
                            <TextBox x:Name="LogOutputText"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     CaretBrush="{DynamicResource Brush.ScrollThumb}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Foreground="{DynamicResource Brush.ScrollThumb}"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     HorizontalContentAlignment="Left"/>
                        </ScrollViewer>
                    </Border>
                    <TextBlock x:Name="StatusText"
                               Grid.Row="2"
                               Margin="16,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Brush.Accent}"
                               FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DetailDismissOverlay"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Panel.ZIndex="9"
                Visibility="Collapsed"
                Background="{DynamicResource Brush.Surface}"
                MouseDown="DetailDismissOverlay_MouseDown"/>

        <Border x:Name="DetailShell"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Width="1080"
                MaxHeight="820"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="10"
                Visibility="Collapsed"
                Margin="26"
                Padding="20"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Effect="{StaticResource PanelShadow}">
            <Grid x:Name="DetailPanelGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>     <!-- 0: 顶部栏 -->
                    <RowDefinition Height="Auto"/>     <!-- 1: Cover + Title/Author -->
                    <RowDefinition Height="Auto"/>     <!-- 2: Tab bar -->
                    <RowDefinition Height="*"/>        <!-- 3: Tab content -->
                    <RowDefinition Height="Auto"/>     <!-- 4: Bottom info bar -->
                </Grid.RowDefinitions>

                <!-- 0: 顶部栏 (复用现有) -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="DetailBackButton"
                            Grid.Column="0"
                            Content="← 返回书库"
                            Click="ReturnToLibrary_Click"
                            Style="{StaticResource DetailTopBarButton}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="EditModeButton"
                                Content="编辑"
                                Click="ToggleEditMode_Click"
                                Style="{StaticResource DetailTopBarButton}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="MoreActionsButton"
                                Content="更多 ▾"
                                Click="OpenMoreActionsMenu_Click"
                                Style="{StaticResource DetailTopBarButton}">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreActionsMenu">
                                    <MenuItem Header="打开所在文件夹" Click="OpenFolder_Click"/>
                                    <MenuItem Header="重新定位" Click="Relocate_Click"/>
                                    <MenuItem x:Name="MoreActionsHideMenuItem" Header="隐藏作品" Click="HideBook_Click"/>
                                    <Separator/>
                                    <MenuItem Header="删除库记录" Click="DeleteBook_Click" Foreground="{DynamicResource Brush.Danger}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 1: Cover 16:9 + Title/Author -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Center">
                    <Border Width="480" Height="270" CornerRadius="{StaticResource RadiusPanel}"
                            Background="#111827" ClipToBounds="True">
                        <Grid>
                            <Border CornerRadius="{StaticResource RadiusPanel}" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="DetailCoverImage" Source="{Binding CoverImage}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <!-- 无 cover 时纯色+🎬 -->
                                    <Border Background="#1E293B">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CoverImage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="🎬" FontSize="64" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="#475569"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- ▶ 播放按钮 -->
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="48" Height="48" CornerRadius="{StaticResource RadiusPanel}"
                                    Background="#CC111827" BorderBrush="#55FFFFFF" BorderThickness="1"
                                    Visibility="{Binding HasVideo, Converter={StaticResource BoolToVisibility}}">
                                <Path Width="16" Height="20" Stretch="Fill" Fill="#F8FAFC"
                                      Data="M 0 0 L 16 10 L 0 20 Z"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="BookTitleText" Margin="0,10,0,2"
                               FontSize="20" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    <TextBlock x:Name="BookAuthorText" FontSize="13" Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- 2: Tab bar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center"
                            x:Name="DetailTabBar">
                    <Button x:Name="VideoTabButton" Tag="video" Content="视频集"
                            Click="DetailTab_Click"
                            MinWidth="80" Height="32" Padding="16,0" Margin="0,0,8,0"
                            Focusable="False" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2"
                            Foreground="{DynamicResource Brush.TextMuted}" FontSize="13" FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                <Style.Triggers>
                                    <Trigger Property="local:TabActive.IsActive" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="GalleryTabButton" Tag="gallery" Content="图集"
                            Click="DetailTab_Click"
                            MinWidth="80" Height="32" Padding="16,0"
                            Focusable="False" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2"
                            Foreground="{DynamicResource Brush.TextMuted}" FontSize="13" FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                <Style.Triggers>
                                    <Trigger Property="local:TabActive.IsActive" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.TextPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 3: Tab content (视频列表 / 图集列表) -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                    <StackPanel>
                        <!-- 旧只读信息面板 (条件显示) -->
                        <StackPanel x:Name="ReadOnlyInfoPanel">
                            <WrapPanel Margin="0,0,0,10" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <StackPanel x:Name="RatingStarsHost" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button x:Name="ToggleFavoriteButton" Content="☆ 收藏" Click="ToggleFavorite_Click" Style="{StaticResource DetailTopBarFavoriteButton}"/>
                                </StackPanel>
                                <Button x:Name="BookAuthorFilterButton" Click="DetailAuthorFilter_Click"
                                        Style="{StaticResource DetailHeroSecondaryButton}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                <Border Height="36" Padding="12,0" Margin="0,0,8,8"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.SurfaceMuted}"
                                        BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                                    <TextBlock x:Name="BookMetaLineText" Style="{StaticResource DetailHeroMetaText}" VerticalAlignment="Center"/>
                                </Border>
                                <ItemsControl x:Name="BookTagChips" Margin="0,0,0,0" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TagChip}">
                                            <Border Style="{StaticResource DetailHeroTagChipBorder}" Background="{Binding Color}"
                                                    MouseEnter="TagChip_MouseEnter" MouseLeave="TagChip_MouseLeave"
                                                    PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                                                    PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                                                    MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="OpenCurrentBookButton" Content="开始阅读" Click="OpenCurrentBook_Click"
                                        Style="{StaticResource DetailHeroPrimaryButton}" Margin="0,0,12,0"/>
                                <Button Content="-1" Click="DecreaseReadCount_Click" Style="{StaticResource DetailHeroSecondaryButton}" Margin="0,0,8,0"/>
                                <Button Content="+1" Click="IncreaseReadCount_Click" Style="{StaticResource DetailHeroSecondaryButton}" Margin="0,0,12,0"/>
                                <Button Content="打开所在文件夹" Click="OpenFolder_Click" Style="{StaticResource DetailHeroSecondaryButton}" Margin="0,0,10,0"/>
                                <Button Content="重新定位" Click="Relocate_Click" Style="{StaticResource DetailHeroSecondaryButton}"/>
                            </StackPanel>

                            <TextBlock x:Name="ReadingStatusInlineText" Style="{StaticResource DetailReadingStatusText}" Margin="0,0,0,12"/>

                            <!-- 隐藏的旧字段控件 -->
                            <StackPanel Visibility="Collapsed">
                                <TextBlock x:Name="ReadOnlyAuthorText"/>
                                <TextBlock x:Name="ReadOnlyForeignNameText"/>
                                <TextBlock x:Name="ReadOnlyPageCountText"/>
                                <TextBlock x:Name="ReadOnlyCoverPageText"/>
                                <TextBlock x:Name="ReadOnlyStatusText"/>
                                <TextBlock x:Name="ReadOnlyReadCountText"/>
                                <TextBlock x:Name="ReadOnlyProducedAtText"/>
                                <TextBlock x:Name="ReadOnlyImportedAtText"/>
                                <TextBlock x:Name="ReadOnlyTagsText"/>
                                <Button x:Name="HideBookButton" Click="HideBook_Click"/>
                            </StackPanel>

                            <Border Margin="0,0,0,12" Padding="0" Background="Transparent">
                                <StackPanel>
                                    <TextBlock Text="简介" Style="{StaticResource DetailSectionTitleText}"/>
                                    <TextBlock x:Name="ReadOnlySummaryText" Style="{StaticResource DetailSummaryText}"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="作品信息" Style="{StaticResource DetailSectionTitleText}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="72"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="作者" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaAuthorValueText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="外文名" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaForeignNameValueText" Grid.Row="0" Grid.Column="4" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaPageCountLabelText" Grid.Row="1" Grid.Column="0" Text="页数" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaPageCountValueText" Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaCoverPageLabelText" Grid.Row="1" Grid.Column="3" Text="封面页" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MetaCoverPageValueText" Grid.Row="1" Grid.Column="4" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="出品时间" Style="{StaticResource DetailMetaLabelText}"/>
                                    <TextBlock x:Name="MetaProducedAtValueText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailMetaValueText}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="录入时间" Style="{StaticResource DetailMetaLabelText}"/>
                                    <TextBlock x:Name="MetaImportedAtValueText" Grid.Row="2" Grid.Column="4" Style="{StaticResource DetailMetaValueText}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- 视频集内容 -->
                        <StackPanel x:Name="DetailVideoContent" Visibility="Collapsed" Margin="0,0,0,12">
                            <DockPanel Margin="0,0,0,8" LastChildFill="True">
                                <Button x:Name="DetailVideoViewToggle"
                                        DockPanel.Dock="Right"
                                        MinWidth="34" Height="26"
                                        Margin="8,0,0,0"
                                        Padding="6,2"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource Brush.TextMuted}"
                                        FontSize="14"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Content="▦"
                                        ToolTip="切换 列表 / 瀑布流"
                                        Click="DetailVideoViewToggle_Click"/>
                                <TextBlock Text="视频列表" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                            </DockPanel>
                            <ItemsControl x:Name="DetailVideoListContainer"
                                          ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,8" Margin="0,0,0,4"
                                                CornerRadius="{StaticResource RadiusControl}"
                                                Background="{DynamicResource Brush.SurfaceMuted}"
                                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="DetailVideoItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="🎬" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                           FontSize="13" Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="▶" FontSize="12" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl x:Name="DetailVideoGrid"
                                          ItemsSource="{Binding}"
                                          Visibility="Collapsed"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.CacheLength="4"
                                          VirtualizingPanel.CacheLengthUnit="Page"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:VirtualizingWrapPanel ItemWidth="214" ItemHeight="360"
                                                                        HorizontalSpacing="18" VerticalSpacing="14"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="198" Height="348" Padding="12"
                                                CornerRadius="10"
                                                Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                Cursor="Hand" RenderTransformOrigin="0.5,0.5"
                                                MouseEnter="VideoCard_MouseEnter"
                                                MouseLeave="VideoCard_MouseLeave"
                                                PreviewMouseLeftButtonDown="VideoCard_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="VideoCard_PreviewMouseLeftButtonUp">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <StackPanel>
                                                <!-- Thumbnail -->
                                                <Grid Width="174" Height="236" HorizontalAlignment="Center">
                                                    <Border Width="168" Height="224" VerticalAlignment="Top"
                                                            CornerRadius="4" ClipToBounds="True"
                                                            Effect="{StaticResource BookShadow}"
                                                            Background="{DynamicResource Brush.SurfaceMuted}">
                                                        <Grid>
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Text="🎬" FontSize="32"
                                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                                       Visibility="{Binding ThumbnailPlaceholderVisibility}"/>
                                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <!-- Text info -->
                                                <StackPanel Margin="0,10,0,0">
                                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold" FontSize="13"
                                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                                               TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                               ToolTip="{Binding FileName}"/>
                                                    <TextBlock Text="{Binding MetaText}" Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}" FontSize="12"
                                                               FontWeight="SemiBold" TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <ItemsControl ItemsSource="{Binding TagItems}" Margin="0,8,0,0"
                                                                  MaxHeight="44" ClipToBounds="True">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="6,2" Margin="0,0,4,4" CornerRadius="9"
                                                                        Background="{Binding Color}" MaxWidth="160">
                                                                    <TextBlock Text="{Binding Name}" FontSize="10"
                                                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                                                               TextTrimming="CharacterEllipsis" MaxWidth="140"
                                                                               ToolTip="{Binding Name}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 图集内容 -->
                        <StackPanel x:Name="DetailGalleryContent" Visibility="Collapsed" Margin="0,0,0,12">
                            <TextBlock Text="图集列表" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="DetailOpenCatalogButton"
                                       Text="打开目录"
                                       Visibility="Collapsed"/>
                            <ItemsControl x:Name="DetailGalleryList" ItemsSource="{Binding ImageSetPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,8" Margin="0,0,0,4"
                                                CornerRadius="{StaticResource RadiusControl}"
                                                Background="{DynamicResource Brush.SurfaceMuted}"
                                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="DetailGalleryItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="📷" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Converter={StaticResource PathToFileName}}"
                                                           FontSize="13" Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="📂" FontSize="12" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 编辑表单 -->
                        <StackPanel x:Name="EditFormPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="编辑作品信息" Style="{StaticResource DetailEditFormHeaderText}"/>
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="书名" Style="{StaticResource LabelText}"/><TextBox x:Name="TitleBox" Margin="0,0,0,14"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="作者" Style="{StaticResource LabelText}"/><TextBox x:Name="AuthorBox" TextChanged="EditAuthorSearchBox_TextChanged" ToolTip="只能选择作者管理中已有作者"/>
                                        <ItemsControl ItemsSource="{Binding EditAuthorOptions, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:AuthorItem}">
                                                    <Border Style="{StaticResource AppTagChipBorder}" Background="{DynamicResource Brush.BorderSubtle}" MouseLeftButtonDown="EditAuthorOption_Click" ToolTip="点击选择作者"><TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/></Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="外文名" Style="{StaticResource LabelText}"/><TextBox x:Name="ForeignNameBox"/></StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="出品时间" Style="{StaticResource LabelText}"/><TextBox x:Name="ProducedAtBox"/></StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="录入时间" Style="{StaticResource LabelText}"/>
                                        <DockPanel><Button x:Name="ImportedTodayButton" DockPanel.Dock="Right" Content="今日" Click="ImportedToday_Click" Style="{StaticResource TinyButton}" Margin="8,0,0,0"/><TextBox x:Name="ImportedAtBox"/></DockPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10" MinHeight="280">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="TagsBox" Visibility="Collapsed"/>
                                    <DockPanel Grid.Column="0"><TextBlock DockPanel.Dock="Top" Text="Tag 管理" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                                        <Border Padding="10,8" CornerRadius="{StaticResource RadiusField}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1">
                                            <DockPanel>
                                                <TextBox x:Name="EditTagSearchBox" DockPanel.Dock="Top" Margin="0,0,0,8" Padding="12,4" TextChanged="EditTagSearchBox_TextChanged" ToolTip="输入关键词搜索已有 Tag"/>
                                                <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="0,4">
                                                    <DockPanel><TextBlock DockPanel.Dock="Left" Text="已选" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" Margin="0,0,8,0"/><ItemsControl ItemsSource="{Binding EditSelectedTagItems, RelativeSource={RelativeSource AncestorType=Window}}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:TagChip}"><Border Style="{StaticResource AppTagChipBorder}" Background="{Binding Color}" Margin="0,0,4,4" MouseLeftButtonDown="EditTagRemove_Click" ToolTip="点击移除"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/><TextBlock Text=" ×" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></DockPanel>
                                                </Border>
                                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                                                    <ItemsControl ItemsSource="{Binding EditTagOptions, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:TagChip}"><Border Style="{StaticResource AppTagChipBorder}" Background="{Binding Color}" Opacity="0.72" Margin="0,0,4,4" MouseLeftButtonDown="EditTagOption_Click" ToolTip="点击添加"><TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                    <DockPanel Grid.Column="2"><TextBlock DockPanel.Dock="Top" Text="简介" Style="{StaticResource LabelText}" Margin="0,0,0,6"/><TextBox x:Name="SummaryBox" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/></DockPanel>
                                </Grid>
                            </StackPanel>
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="危险操作" Style="{StaticResource DetailSectionTitleText}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="PrivacyCoverButtonEdit" Content="隐私封面" Click="ToggleBookPrivacyCover_Click" Style="{StaticResource DetailFileActionButton}"/>
                                        <Button x:Name="HideBookButtonEdit" Content="隐藏作品" Click="HideBook_Click" Style="{StaticResource DetailFileActionButton}"/>
                                        <Button Content="删除库记录" Click="DeleteBook_Click" Style="{StaticResource DetailDangerInlineButton}"/>
                                        <Button x:Name="DeleteSourceButton" Content="删除源文件" Click="DeleteSourceFiles_Click" Style="{StaticResource DetailDangerInlineButton}" Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="24,0,0,0">
                                    <Button Content="取消" Click="ToggleEditMode_Click" Style="{StaticResource DetailHeroSecondaryButton}" Height="38" MinHeight="38" Padding="18,0" Margin="0,0,10,0"/>
                                    <Button x:Name="SaveMetadataButton" Content="保存信息" Click="SaveMetadata_Click" Style="{StaticResource DetailHeroPrimaryButton}" Height="38" MinHeight="38" Padding="18,0" MinWidth="0"/>
                                </StackPanel>
                            </Grid>
                            <Border Visibility="Collapsed">
                                <StackPanel><TextBox x:Name="CoverPageBox"/><TextBox x:Name="ReadCountBox"/><ComboBox x:Name="ReadingStatusBox" SelectedIndex="0"><ComboBoxItem Content="未读" Tag="unread"/><ComboBoxItem Content="在读" Tag="reading"/></ComboBox></StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock x:Name="EditModeHintText" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 4: Bottom info bar -->
                <Border Grid.Row="4" Padding="8,8,8,0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Brush.BorderSubtle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="DetailPlayAllButton" Content="▶ 播放全部"
                                Click="DetailPlayAll_Click"
                                Style="{StaticResource AppButton}" MinHeight="30" Padding="12,4" FontSize="12"/>
                        <TextBlock Grid.Column="2" x:Name="DetailInfoBarText"
                                   FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="DetailCatalogOverlay"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Panel.ZIndex="18"
              Visibility="Collapsed"
              Background="{DynamicResource Brush.TextPrimary}"
              MouseLeftButtonDown="DetailCatalogOverlay_MouseLeftButtonDown"
              PreviewMouseWheel="DetailCatalogOverlay_PreviewMouseWheel">
            <Border Width="1120"
                    MaxHeight="760"
                    Margin="26"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Effect="{StaticResource PanelShadow}"
                    MouseLeftButtonDown="DetailCatalogContent_MouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DetailCatalogTitleText"
                                       Text="目录"
                                       FontSize="24"
                                       FontWeight="Black"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="900"
                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="关闭"
                                Click="CloseDetailCatalog_Click"
                                Style="{StaticResource DetailHeroSecondaryButton}"
                                VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="548"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="DetailCatalogList"
                                 ItemsSource="{Binding DetailPageCatalogItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PageCatalogItem}">
                                    <Border Width="118"
                                            Height="176"
                                            Margin="6"
                                            Padding="7"
                                            CornerRadius="{StaticResource RadiusControl}"
                                            Background="{DynamicResource Brush.SurfaceMuted}"
                                            BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseEnter="DetailCatalogItem_MouseEnter"
                                            MouseLeftButtonDown="DetailCatalogItem_MouseLeftButtonDown">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="从此处开始阅读" Click="StartReadingFromCatalog_Click"/>
                                                <MenuItem Header="设为封面" Click="SetDetailCatalogPageAsCover_Click"/>
                                                <MenuItem Header="标记此页" Click="MarkDetailCatalogBookmark_Click"
                                                          Visibility="{Binding IsNotBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                                <MenuItem Header="编辑标记内容" Click="EditDetailCatalogBookmark_Click"
                                                          Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                                <MenuItem Header="取消标记" Click="RemoveDetailCatalogBookmark_Click"
                                                          Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                                <MenuItem Header="删除源文件（需密码）" Click="DeleteSourceFromCatalog_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Border CornerRadius="{StaticResource RadiusControl}"
                                                        Background="{DynamicResource Brush.TextPrimary}"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="LowQuality"/>
                                                </Border>
                                                <Path Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,6,6"
                                                      Data="M0,0 L20,0 L20,24 L10,18 L0,24 Z"
                                                      Fill="{Binding BookmarkBrush}"
                                                      Stroke="{DynamicResource Brush.BorderSubtle}"
                                                      StrokeThickness="1"/>
                                            </Grid>
                                            <StackPanel Grid.Row="1"
                                                        Margin="0,7,0,0"
                                                        HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding PageText}"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding BookmarkLabel}"
                                                           Margin="0,3,0,0"
                                                           HorizontalAlignment="Stretch"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           FontSize="10"
                                                           FontWeight="Normal"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding BookmarkLabel}"
                                                           Visibility="{Binding HasBookmarkLabel, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Column="1"
                                Margin="18,0,0,0"
                                Padding="14"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="{DynamicResource Brush.SurfaceMuted}"
                                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.TextPrimary}"
                                        ClipToBounds="True">
                                    <Image x:Name="DetailCatalogPreviewImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock x:Name="DetailCatalogPreviewText"
                                           Grid.Row="1"
                                           Text="选择一页预览"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="ToastPanel"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40"
                Padding="20,10"
                CornerRadius="{StaticResource RadiusControl}"
                Background="{DynamicResource Brush.TextPrimary}"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Panel.ZIndex="100">
            <TextBlock x:Name="ToastText"
                       Foreground="{DynamicResource Brush.Surface}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>
