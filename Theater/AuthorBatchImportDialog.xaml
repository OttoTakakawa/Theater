<Window x:Class="Theater.AuthorBatchImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Theater.Models"
        Title="批量导入"
        Width="860"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Text="是否作为作者批量导入？" Style="{StaticResource AppDialogTitleText}" MaxHeight="72"/>
                        <TextBlock Text="确认作者名、逐本修正标题，然后一次性写入书库。" Style="{StaticResource AppDialogSubtitleText}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}" VerticalAlignment="Top"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="作者名" Style="{StaticResource AppDialogLabelText}"/>
                        <TextBox x:Name="AuthorBox" Margin="0,8,0,0" Style="{StaticResource AppDialogTextBox}"/>
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="识别目录" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBlock x:Name="FolderCountText" Margin="0,6,0,0" FontSize="24" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="将导入" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBlock x:Name="BookCountText" Margin="0,6,0,0" FontSize="24" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="标题可在导入前逐本修改；Tag 来自脚本预判，导入后仍可继续编辑。"
                           Margin="0,18,0,10"
                           Foreground="{DynamicResource Brush.TextMuted}"/>

                <Border Grid.Row="3" Style="{StaticResource AppDialogPanelBorder}" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="CandidateList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:BatchImportCandidate}">
                                    <Border Margin="0,0,0,10" Style="{StaticResource AppDialogListItemBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" MinWidth="0"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="3"
                                                       Text="{Binding FolderName}"
                                                       ToolTip="{Binding FolderName}"
                                                       Margin="14,0,14,0"
                                                       Style="{StaticResource AppDialogLabelText}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="0"
                                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding Title}"
                                                     Margin="0,8,0,0"
                                                     Height="44"
                                                     VerticalContentAlignment="Center"
                                                     MaxLines="1"
                                                     TextWrapping="NoWrap"
                                                     HorizontalScrollBarVisibility="Hidden"
                                                     Style="{StaticResource AppDialogTextBox}"/>
                                            <Border Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="0,8,0,0"
                                                    Height="44"
                                                    CornerRadius="{StaticResource RadiusControl}"
                                                    Background="{DynamicResource Brush.Surface}"
                                                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                                                    BorderThickness="1"
                                                    Padding="12,0"
                                                    VerticalAlignment="Stretch">
                                                <TextBlock Text="{Binding SummaryText}"
                                                           TextAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding SummaryText}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <DockPanel Grid.Row="4" Margin="0,22,0,0">
                    <TextBlock x:Name="HintText" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                        <Button Content="确认导入" Width="124" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
