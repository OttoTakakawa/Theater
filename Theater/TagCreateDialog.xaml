<Window x:Class="Theater.TagCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建标签"
        Width="624"
        Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" Padding="26" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                <TextBlock Text="新建标签" Style="{StaticResource AppDialogTitleText}"/>
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Text="互斥标签：同一分组只允许一本书保留一个；不互斥标签适合题材、主题、风格。"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       TextWrapping="Wrap"/>

            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="标签名称" Style="{StaticResource AppDialogLabelText}"/>
                    <TextBox x:Name="TagNameBox" Margin="0,8,0,0" Style="{StaticResource AppDialogTextBox}" TextChanged="TagNameBox_TextChanged"/>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="标签分组（可输入自定义）" Style="{StaticResource AppDialogLabelText}"/>
                        <ComboBox x:Name="TagCategoryBox" Margin="0,8,0,0" Style="{StaticResource AppDialogEditableComboBox}" SelectionChanged="TagCategoryBox_Changed" LostFocus="TagCategoryBox_LostFocus"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="规则" Style="{StaticResource AppDialogLabelText}"/>
                        <ComboBox x:Name="TagTypeBox" Margin="0,8,0,0" Style="{StaticResource AppDialogComboBox}">
                            <ComboBoxItem Content="互斥"/>
                            <ComboBoxItem Content="不互斥"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,22,0,0">
                <TextBlock Text="标签颜色" Style="{StaticResource AppDialogLabelText}"/>
                <Grid x:Name="ColorPickerArea" Margin="0,10,0,0">
                    <WrapPanel VerticalAlignment="Top">
                        <ItemsControl x:Name="PresetColorPicker">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ColorSwatchBorderStyle}"
                                            Background="{Binding}"
                                            MouseLeftButtonDown="ColorSwatch_Click"
                                            Margin="0,0,8,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border x:Name="AddCustomColorButton"
                                Style="{StaticResource AddColorSwatchBorderStyle}"
                                Margin="0,0,8,0"
                                MouseLeftButtonDown="AddCustomColor_Click"
                                ToolTip="添加自定义颜色">
                            <TextBlock Text="+" Foreground="{DynamicResource Brush.TextMuted}" FontSize="22"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </WrapPanel>
                </Grid>
                <TextBlock x:Name="CategoryHintText" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Visibility="Collapsed"/>
                <Border x:Name="SelectedColorPreview" Margin="0,8,0,0" Padding="12,6" CornerRadius="{StaticResource RadiusTag}" HorizontalAlignment="Left" SnapsToDevicePixels="True">
                    <TextBlock x:Name="SelectedColorText" FontSize="12" Foreground="{DynamicResource Brush.TextPrimary}"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,8">
                <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                <Button x:Name="ConfirmButton" Content="创建" Width="104" Click="Confirm_Click" Style="{StaticResource AppDialogButton}" IsEnabled="False"/>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
