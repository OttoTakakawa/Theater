<Window x:Class="Theater.UpdateCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查更新"
        Width="500"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="DialogTitleText"
                               Text="检查更新"
                               Style="{StaticResource AppDialogTitleText}"/>
                    <TextBlock x:Name="DialogDescriptionText"
                               Text="正在连接本地更新包与 GitHub Release。"
                               Style="{StaticResource AppDialogSubtitleText}"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="UpdateProgressBar"
                                 Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="True"
                                 Value="0"/>

                    <TextBlock x:Name="UpdatePercentText"
                               Grid.Row="1"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource Brush.Accent}"
                               FontSize="12"
                               Visibility="Collapsed"
                               Text="0%"/>

                    <TextBlock x:Name="UpdateMessageText"
                               Grid.Row="2"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               FontSize="13"/>
                </Grid>

                <DockPanel Grid.Row="2" Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CloseButton"
                                Content="关闭"
                                Width="104"
                                Margin="0,0,10,0"
                                Click="CloseButton_Click"
                                Style="{StaticResource AppDialogGhostButton}"/>
                        <Button x:Name="InstallButton"
                                Content="安装更新"
                                Width="116"
                                Click="InstallButton_Click"
                                Visibility="Collapsed"
                                Style="{StaticResource AppDialogButton}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
