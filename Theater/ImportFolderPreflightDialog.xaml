<Window x:Class="Theater.ImportFolderPreflightDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导入预检"
        Width="760"
        Height="720"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="这个文件夹同时像『单部作品』和『作者文件夹』"
                                   Style="{StaticResource AppDialogTitleText}"
                                   MaxHeight="72"/>
                        <TextBlock Text="所选目录本身包含视频或图片，同时它的子目录也包含内容。为了避免误导入，请确认你想采用哪种结构。"
                                   Style="{StaticResource AppDialogSubtitleText}"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1" Margin="0,22,0,0" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="当前目录" Style="{StaticResource AppDialogLabelText}"/>
                        <TextBlock x:Name="RootPathText"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="当前目录内容" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBlock x:Name="DirectImageCountText" Margin="0,8,0,0" FontSize="24" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <TextBlock Text="按单本导入时，当前目录会被识别为 1 部作品。"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="子目录作品" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBlock x:Name="ChildBookCountText" Margin="0,8,0,0" FontSize="24" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <TextBlock Text="按作者文件夹导入时，子目录会被识别为多部作品。"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Margin="0,14,0,0" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="标准作者文件夹" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBlock Text="只创建目录，不移动文件，不修改数据库。用于把散落作品先整理到标准作者目录。"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"/>
                            <TextBox x:Name="StandardAuthorBox"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource AppDialogTextBox}"
                                     ToolTip="标准作者文件夹名称"/>
                            <CheckBox x:Name="CreateInboxFolderBox"
                                      Content="同时创建“待整理”子目录"
                                      Margin="2,10,0,0"
                                      Foreground="{DynamicResource Brush.TextMuted}"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="创建标准作者文件夹"
                                VerticalAlignment="Bottom"
                                Click="CreateStandardFolder_Click"
                                Style="{StaticResource AppDialogGhostButton}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Margin="0,14,0,0" Style="{StaticResource AppDialogPanelBorder}" Padding="12" MaxHeight="240">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChildFolderList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="12,8"
                                            CornerRadius="{StaticResource RadiusControl}"
                                            Background="{DynamicResource Brush.SurfaceMuted}"
                                            BorderBrush="{DynamicResource Brush.ScrollTrack}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <DockPanel Grid.Row="5" Margin="0,18,0,0">
                    <TextBlock x:Name="HintText" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="打开本地文件夹" Click="OpenFolder_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="取消" Width="86" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="按单本导入" Width="118" Click="ImportSingle_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
                        <Button Content="按作者文件夹导入" Width="154" Click="ImportAuthor_Click" Style="{StaticResource AppDialogButton}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
