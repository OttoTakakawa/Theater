<Window x:Class="Theater.BookmarkLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书签标签"
        Width="520"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ShowActivated="True"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="书签标签" Style="{StaticResource AppDialogTitleText}"/>
                    <TextBlock Text="为当前页书签添加一个标签（可选），方便快速识别。"
                               Style="{StaticResource AppDialogSubtitleText}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <TextBlock Text="标签文字" Style="{StaticResource AppDialogLabelText}"/>
                    <TextBox x:Name="LabelBox"
                             Margin="0,8,0,0"
                             MaxLength="50"
                             Style="{StaticResource AppDialogTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="跳过" Width="104" Margin="0,0,10,0" Click="Skip_Click" Style="{StaticResource AppDialogGhostButton}"/>
                    <Button Content="保存" Width="104" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
