<Window x:Class="Theater.LibraryGovernanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="资料库治理"
        Width="1160"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Text="资料库治理"
                   FontSize="22"
                   FontWeight="Black"
                   Foreground="{DynamicResource Brush.TextPrimary}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.SurfaceMuted}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock x:Name="SummaryText"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20"/>
                <WrapPanel Margin="0,12,0,0">
                    <TextBox x:Name="SearchBox"
                             Width="280"
                             Margin="0,0,10,0"
                             Style="{StaticResource AppDialogTextBox}"
                             TextChanged="Filter_Changed"/>
                    <ComboBox x:Name="GroupFilterBox"
                              Width="220"
                              Margin="0,0,10,0"
                              Style="{StaticResource AppDialogComboBox}"
                              SelectionChanged="Filter_Changed"/>
                    <TextBlock x:Name="CountText"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="12"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.7*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Padding="8">
                <ListView x:Name="ItemsList"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionChanged="ItemsList_SelectionChanged"
                          MouseDoubleClick="ItemsList_MouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="分组" Width="170" DisplayMemberBinding="{Binding GroupTitle}"/>
                            <GridViewColumn Header="条目" Width="250" DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="摘要" Width="370" DisplayMemberBinding="{Binding Subtitle}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.SurfaceMuted}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="ItemTitleText"
                                   Text="请选择左侧条目"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontSize="16"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="ItemSubtitleText"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBox x:Name="DetailTextBox"
                             Grid.Row="1"
                             Margin="0,14,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource Brush.TextPrimary}"
                             FontFamily="Consolas"
                             FontSize="13"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SearchButton" Content="搜索标题" Click="Search_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
            <Button x:Name="AuthorButton" Content="按作者筛选" Click="Author_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
            <Button x:Name="DetailButton" Content="打开详情" Click="Detail_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
            <Button x:Name="FolderButton" Content="打开目录" Click="Folder_Click" Style="{StaticResource AppDialogGhostButton}" Margin="0,0,8,0"/>
            <Button Content="关闭" Click="Close_Click" Style="{StaticResource AppDialogButton}" Width="96"/>
        </StackPanel>
    </Grid>
</Window>
