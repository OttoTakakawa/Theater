<Window x:Class="Theater.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Theater.Controls"
        Title="阅读器" Height="900" Width="1280" MinHeight="720" MinWidth="980"
        Background="{DynamicResource Brush.Reader.Bg}" WindowStartupLocation="CenterOwner" Opacity="1"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <DropShadowEffect x:Key="ToolbarShadow" Color="#000000" BlurRadius="26" ShadowDepth="8" Opacity="0.28"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Reader.ButtonBgDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Reader.ButtonBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusControl}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Reader.ButtonHoverBg}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Reader.ButtonHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Reader.ButtonPressedBg}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Reader.ButtonPressedBorder}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Reader.ComboBoxBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.Text}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Reader.ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusControl}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="{DynamicResource Brush.Reader.Decoration}"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Top"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,0,0,8"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="{DynamicResource Brush.Reader.PopupBg}"
                                        BorderBrush="{DynamicResource Brush.Reader.PopupBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Effect="{StaticResource ToolbarShadow}">
                                    <ScrollViewer MaxHeight="240">
                                        <ItemsPresenter Margin="5"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Brush.Reader.ComboBoxHoverBg}"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Brush.Reader.ComboBoxHoverBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.ItemFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusControl}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.Reader.ItemHighlightBg}"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource Brush.Reader.ItemHighlightBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.ItemHighlightFg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.Reader.ItemSelectedBg}"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource Brush.Reader.ItemSelectedBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.ItemHighlightFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track" VerticalAlignment="Center" Height="22">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Focusable="False" Height="4" Background="{DynamicResource Brush.Reader.SliderTrack}" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="{StaticResource RadiusScrollTrack}" Background="{DynamicResource Brush.Reader.SliderTrack}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Focusable="False" Height="4" Background="{DynamicResource Brush.Reader.SliderTrack}" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="{StaticResource RadiusScrollTrack}" Background="{DynamicResource Brush.Reader.SliderTrack}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="{DynamicResource Brush.Reader.SliderThumb}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="16" Height="16" CornerRadius="{StaticResource RadiusControl}" Background="{DynamicResource Brush.Reader.SliderThumb}" BorderBrush="{DynamicResource Brush.Reader.SliderThumbBorder}" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="ReaderRoot"
                          Background="{DynamicResource Brush.Reader.SurfaceDeep}"
          PreviewMouseMove="ReaderRoot_PreviewMouseMove"
          PreviewMouseRightButtonDown="ReaderRoot_PreviewMouseRightButtonDown"
          PreviewMouseRightButtonUp="ReaderRoot_PreviewMouseRightButtonUp">
        <Border x:Name="ReaderBackdrop" Margin="0" Background="{DynamicResource Brush.Reader.SurfaceDeep}">
            <ScrollViewer x:Name="ReaderScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
          Background="{DynamicResource Brush.Reader.SurfaceDeep}"
                          Padding="6"
                          PreviewMouseDown="ReaderScrollViewer_PreviewMouseDown"
                          PreviewMouseWheel="ReaderScrollViewer_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="ReaderScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="ReaderScrollViewer_PreviewMouseLeftButtonUp"
                          PreviewMouseMove="ReaderScrollViewer_PreviewMouseMove">
                <Grid x:Name="ImageScrollContent">
                    <StackPanel x:Name="ImageHost"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Reader.ImageHostBg}">
                        <Image x:Name="ReaderImage" Margin="4" Stretch="None" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Image x:Name="ReaderImageRight" Margin="4" Stretch="None" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel.LayoutTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                        </StackPanel.LayoutTransform>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border x:Name="ReaderMessagePanel"
                Panel.ZIndex="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="680"
                Padding="22,18"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{DynamicResource Brush.Reader.MessageBg}"
                BorderBrush="{DynamicResource Brush.Reader.MessageBorder}"
                BorderThickness="1"
                Visibility="Collapsed"
                Effect="{StaticResource ToolbarShadow}">
            <StackPanel>
                <TextBlock x:Name="ReaderMessageTitle"
                           Text="正在读取页面"
                           FontSize="20"
                           FontWeight="Black"
                           Foreground="{DynamicResource Brush.Reader.MessageText}"
                           TextAlignment="Center"/>
                <TextBlock x:Name="ReaderMessageText"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource Brush.Reader.MessageSubtext}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid x:Name="NextBookConfirmOverlay"
              Panel.ZIndex="18"
              Background="{DynamicResource Brush.Reader.ScrimDark}"
              Visibility="Collapsed"
              PreviewMouseWheel="NextBookConfirmOverlay_PreviewMouseWheel">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="560"
                    Padding="26"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.Reader.Confirm}"
                    BorderBrush="{DynamicResource Brush.Reader.ButtonBorder}"
                    BorderThickness="1"
                    Effect="{StaticResource ToolbarShadow}">
                <StackPanel>
                    <TextBlock Text="已经读到最后一页"
                               FontSize="20"
                               FontWeight="Black"
                               Foreground="{DynamicResource Brush.Reader.Text}"
                               Margin="0,0,0,18"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border x:Name="NextBookCard1"
                                Width="140"
                                Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseLeftButtonDown="NextBookCard1_Click">
                            <StackPanel>
                                <Border Width="120" Height="160"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.Reader.ButtonBg}"
                                        HorizontalAlignment="Center"
                                        ClipToBounds="True">
                                    <Image x:Name="NextBookCover1" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock x:Name="NextBookTitle1"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Reader.CardTitle}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="130"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NextBookCard2"
                                Width="140"
                                Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseLeftButtonDown="NextBookCard2_Click">
                            <StackPanel>
                                <Border Width="120" Height="160"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.Reader.ButtonBg}"
                                        HorizontalAlignment="Center"
                                        ClipToBounds="True">
                                    <Image x:Name="NextBookCover2" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock x:Name="NextBookTitle2"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Reader.CardTitle}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="130"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NextBookCard3"
                                Width="140"
                                Cursor="Hand"
                                MouseLeftButtonDown="NextBookCard3_Click">
                            <StackPanel>
                                <Border Width="120" Height="160"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.Reader.ButtonBg}"
                                        HorizontalAlignment="Center"
                                        ClipToBounds="True">
                                    <Image x:Name="NextBookCover3" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock x:Name="NextBookTitle3"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Reader.CardTitle}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="130"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Margin="0,0,0,18"
                            Padding="14,10"
                            CornerRadius="{StaticResource RadiusControl}"
                            Background="{DynamicResource Brush.Reader.ButtonBgDark}"
                            BorderBrush="{DynamicResource Brush.Reader.ButtonBorder}"
                            BorderThickness="1">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="读完评分"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Reader.Text}"/>
                                <TextBlock x:Name="QuickRatingText"
                                           Text="未评分"
                                           FontSize="11"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource Brush.Reader.SubtleText}"/>
                            </StackPanel>
                            <StackPanel x:Name="QuickRatingStarsHost"
                                        DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="18,0,0,0"/>
                        </DockPanel>
                    </Border>
                    <UniformGrid Columns="3"
                                 HorizontalAlignment="Center">
                        <Button Content="返回第一页"
                                MinWidth="132"
                                Height="42"
                                Padding="16,0"
                                VerticalContentAlignment="Center"
                                Margin="0,0,8,0"
                                Style="{StaticResource ReaderButton}"
                                Click="NextBookGoFirst_Click"/>
                        <Button Content="打开详情页"
                                MinWidth="132"
                                Height="42"
                                Padding="16,0"
                                VerticalContentAlignment="Center"
                                Margin="4,0"
                                Style="{StaticResource ReaderButton}"
                                Click="OpenDetailFromReader_Click"/>
                        <Button Content="留在当前页"
                                MinWidth="132"
                                Height="42"
                                Padding="16,0"
                                VerticalContentAlignment="Center"
                                Margin="8,0,0,0"
                                Style="{StaticResource ReaderButton}"
                                Click="NextBookCancel_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="PageCatalogOverlay"
              Panel.ZIndex="16"
              Background="{DynamicResource Brush.Reader.ScrimDarker}"
              Visibility="Collapsed"
              MouseLeftButtonDown="PageCatalogOverlay_MouseLeftButtonDown"
              PreviewMouseWheel="PageCatalogOverlay_PreviewMouseWheel">
            <Border Margin="42"
                    Padding="20"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{DynamicResource Brush.Reader.Overlay}"
                    BorderBrush="{DynamicResource Brush.Reader.ButtonBorder}"
                    BorderThickness="1"
                    Effect="{StaticResource ToolbarShadow}"
                    MouseLeftButtonDown="PageCatalogContent_MouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="目录"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Foreground="{DynamicResource Brush.Reader.Text}"/>
                            <TextBlock Text="左键跳转页面；右键可将图片设为封面。"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource Brush.Reader.SubtleText}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="关闭"
                                Style="{StaticResource ReaderButton}"
                                Click="ClosePageCatalog_Click"
                                VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox x:Name="PageCatalogList"
                             Grid.Row="1"
                             ItemsSource="{Binding PageCatalogItems}"
                             Background="Transparent"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.CacheLength="0.5"
                             VirtualizingPanel.CacheLengthUnit="Page"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel ItemWidth="156"
                                                                ItemHeight="224"
                                                                HorizontalSpacing="0"
                                                                VerticalSpacing="0"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="142"
                                        Height="210"
                                        Margin="7"
                                        Padding="8"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Background="{DynamicResource Brush.Reader.CatalogItemBg}"
                                        BorderBrush="{DynamicResource Brush.Reader.CatalogItemBorder}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Loaded="PageCatalogItem_Loaded"
                                        MouseLeftButtonDown="PageCatalogItem_MouseLeftButtonDown">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="设为封面" Click="SetCatalogPageAsCover_Click"/>
                                            <MenuItem Header="标记此页" Click="MarkCatalogBookmark_Click"
                                                      Visibility="{Binding IsNotBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                            <MenuItem Header="编辑标记内容" Click="EditCatalogBookmark_Click"
                                                      Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                            <MenuItem Header="取消标记" Click="RemoveCatalogBookmark_Click"
                                                      Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Border CornerRadius="{StaticResource RadiusControl}"
                                                    Background="{DynamicResource Brush.Reader.CatalogImageBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                                            </Border>
                                            <Path Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibility}}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top"
                                                  Margin="0,0,6,6"
                                                  Data="M0,0 L20,0 L20,24 L10,18 L0,24 Z"
                                                  Fill="{Binding BookmarkBrush}"
                                                  Stroke="{DynamicResource Brush.Reader.BookmarkStroke}"
                                                  StrokeThickness="1"/>
                                        </Grid>
                                        <StackPanel Grid.Row="1"
                                                    Margin="0,8,0,0"
                                                    HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding PageText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.Reader.Decoration}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding BookmarkLabel}"
                                                       Margin="0,3,0,0"
                                                       HorizontalAlignment="Stretch"
                                                       Foreground="{DynamicResource Brush.Reader.SubtleText}"
                                                       FontSize="10"
                                                       FontWeight="Normal"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding BookmarkLabel}"
                                                       Visibility="{Binding HasBookmarkLabel, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="TopToolbar"
                Panel.ZIndex="10"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,14,0,0"
                Padding="18,9"
                Background="{DynamicResource Brush.Reader.ToolbarTop}"
                BorderBrush="{DynamicResource Brush.Reader.ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Effect="{StaticResource ToolbarShadow}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="{DynamicResource Brush.Reader.Text}" FontSize="14" FontWeight="SemiBold" MaxWidth="520" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <Border Width="1" Height="14" Margin="12,0" Background="{DynamicResource Brush.Reader.ToolbarDivider}"/>
                <TextBlock x:Name="PageText" Foreground="{DynamicResource Brush.Reader.Decoration}" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border x:Name="BottomToolbar"
                Panel.ZIndex="10"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,18"
                Padding="12,9"
                Background="{DynamicResource Brush.Reader.ToolbarBottom}"
                BorderBrush="{DynamicResource Brush.Reader.ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusPanel}"
                Effect="{StaticResource ToolbarShadow}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 适配模式组 -->
                <Button x:Name="FitWidthButton" Content="适宽" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="FitWidth_Click"/>
                <Button x:Name="FitHeightButton" Content="适高" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="FitHeight_Click"/>
                <Button x:Name="OriginalSizeButton" Content="原始" Style="{StaticResource ReaderButton}" Click="OriginalSize_Click"/>
                <Border Width="1" Height="24" Background="{DynamicResource Brush.Reader.ButtonBorder}" Margin="12,0"/>
                <!-- 质量与背景组 -->
                <Button x:Name="QualityModeButton" Content="质量" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="ToggleQualityModeButton_Click"/>
                <Button x:Name="BackgroundButton" Content="背景" Style="{StaticResource ReaderButton}" Click="CycleBackgroundButton_Click"/>
                <Border Width="1" Height="24" Background="{DynamicResource Brush.Reader.ButtonBorder}" Margin="12,0"/>
                <!-- 页面模式组 -->
                <ComboBox x:Name="ReadingModeBox" MinWidth="60" Margin="0,0,6,0" VerticalAlignment="Center" SelectionChanged="ReadingModeBox_SelectionChanged">
                    <ComboBoxItem Content="单页" IsSelected="True"/>
                    <ComboBoxItem Content="双页"/>
                </ComboBox>
                <ComboBox x:Name="DirectionBox" MinWidth="76" Margin="0,0,6,0" VerticalAlignment="Center" SelectionChanged="ReadingModeBox_SelectionChanged">
                    <ComboBoxItem Content="从左到右" IsSelected="True"/>
                    <ComboBoxItem Content="从右到左"/>
                </ComboBox>
                <StackPanel x:Name="DoublePageGapPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="DoublePageGapText" Text="间距 8" Foreground="{DynamicResource Brush.Reader.Text}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="DoublePageGapSlider" Minimum="0" Maximum="80" Value="8" Width="70" VerticalAlignment="Center" ValueChanged="DoublePageGapSlider_ValueChanged" Focusable="False"/>
                </StackPanel>
                <Border Width="1" Height="24" Background="{DynamicResource Brush.Reader.ButtonBorder}" Margin="12,0"/>
                <!-- 滚轮模式组 -->
                <ComboBox x:Name="WheelModeBox" MinWidth="76" Margin="0,0,0,0" VerticalAlignment="Center" SelectionChanged="WheelModeBox_SelectionChanged">
                    <ComboBoxItem Content="滚轮翻页" IsSelected="True"/>
                    <ComboBoxItem Content="滚轮缩放"/>
                    <ComboBoxItem Content="滚轮滚动"/>
                </ComboBox>
                <Border Width="1" Height="24" Background="{DynamicResource Brush.Reader.ButtonBorder}" Margin="12,0"/>
                <!-- 功能组 -->
                <Button x:Name="CatalogButton" Content="目录" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="CatalogButton_Click"/>
                <Button x:Name="SignButton" Content="标记" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="SignButton_Click"/>
                <Button x:Name="ToggleControlsButton" Content="隐藏" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="ToggleControlsButton_Click"/>
                <Button x:Name="MoreMenuButton" Content="更多" Style="{StaticResource ReaderButton}" Margin="0,0,6,0" Click="MoreMenuButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="MoreMenu">
                            <MenuItem Header="打开详情页" Click="OpenDetailFromReader_Click"/>
                            <Separator/>
                            <MenuItem Header="返回第一页" Click="NextBookGoFirst_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="FullscreenButton" Content="全屏" Style="{StaticResource ReaderButton}" Click="FullscreenButton_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="HiddenControlsBadge"
                Panel.ZIndex="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="14,14,0,0"
                Padding="13,8"
                CornerRadius="{StaticResource RadiusControl}"
                Background="{DynamicResource Brush.Reader.Hint}"
                BorderBrush="{DynamicResource Brush.Reader.ToolbarBorder}"
                BorderThickness="1"
                Visibility="Collapsed"
                MouseLeftButtonDown="HiddenControlsBadge_MouseLeftButtonDown">
            <StackPanel>
                <TextBlock Text="显示 UI" Foreground="{DynamicResource Brush.Reader.Text}" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock x:Name="HiddenPageText" Text="1 / 1" Foreground="{DynamicResource Brush.Reader.Decoration}" FontSize="11" FontWeight="SemiBold" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
