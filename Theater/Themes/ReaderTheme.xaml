    <SolidColorBrush x:Key="Brush.Reader.ItemHighlightBg" Color="{StaticResource Color.Reader.ItemHighlightBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ItemHighlightBorder" Color="{StaticResource Color.Reader.ItemHighlightBorder}"/>
