    <SolidColorBrush x:Key="Brush.Reader.Text" Color="{StaticResource Color.Reader.Text}"/>
    <SolidColorBrush x:Key="Brush.Reader.TextMuted" Color="{StaticResource Color.Reader.TextMuted}"/>
    <SolidColorBrush x:Key="Brush.Reader.Decoration" Color="{StaticResource Color.Reader.Decoration}"/>
    <SolidColorBrush x:Key="Brush.Reader.SubtleText" Color="{StaticResource Color.Reader.SubtleText}"/>
    <SolidColorBrush x:Key="Brush.Reader.CardTitle" Color="{StaticResource Color.Reader.CardTitle}"/>
    <SolidColorBrush x:Key="Brush.Reader.Border" Color="{StaticResource Color.Reader.Border}"/>
    <SolidColorBrush x:Key="Brush.Reader.ToolbarBorder" Color="{StaticResource Color.Reader.ToolbarBorder}"/>
