    <SolidColorBrush x:Key="Brush.Reader.CatalogItemBorder" Color="{StaticResource Color.Reader.CatalogItemBorder}"/>
    <SolidColorBrush x:Key="Brush.Reader.CatalogImageBg" Color="{StaticResource Color.Reader.CatalogImageBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.BookmarkStroke" Color="{StaticResource Color.Reader.BookmarkStroke}"/>
    <SolidColorBrush x:Key="Brush.Reader.MessageBg" Color="{StaticResource Color.Reader.MessageBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.MessageBorder" Color="{StaticResource Color.Reader.MessageBorder}"/>
    <SolidColorBrush x:Key="Brush.Reader.MessageText" Color="{StaticResource Color.Reader.MessageText}"/>
    <SolidColorBrush x:Key="Brush.Reader.MessageSubtext" Color="{StaticResource Color.Reader.MessageSubtext}"/>

    <Style x:Key="ReaderButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
        <Setter Property="Background" Value="{DynamicResource Brush.Reader.ButtonBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Reader.ButtonBorder}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Reader.Text}"/>
    </Style>

    <Style x:Key="ReaderGhostButton" TargetType="Button" BasedOn="{StaticResource ReaderButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Reader.Border}"/>
    </Style>
</ResourceDictionary>
