    <SolidColorBrush x:Key="Brush.Reader.Overlay" Color="{StaticResource Color.Reader.Overlay}"/>
    <SolidColorBrush x:Key="Brush.Reader.Confirm" Color="{StaticResource Color.Reader.Confirm}"/>
    <SolidColorBrush x:Key="Brush.Reader.Hint" Color="{StaticResource Color.Reader.Hint}"/>
    <SolidColorBrush x:Key="Brush.Reader.ScrimDark" Color="{StaticResource Color.Reader.ScrimDark}"/>
    <SolidColorBrush x:Key="Brush.Reader.ScrimDarker" Color="{StaticResource Color.Reader.ScrimDarker}"/>
    <SolidColorBrush x:Key="Brush.Reader.SliderTrack" Color="{StaticResource Color.Reader.SliderTrack}"/>
    <SolidColorBrush x:Key="Brush.Reader.SliderThumb" Color="{StaticResource Color.Reader.SliderThumb}"/>
    <SolidColorBrush x:Key="Brush.Reader.SliderThumbBorder" Color="{StaticResource Color.Reader.SliderThumbBorder}"/>
    <SolidColorBrush x:Key="Brush.Reader.ButtonBg" Color="{StaticResource Color.Reader.ButtonBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ButtonBgDark" Color="{StaticResource Color.Reader.ButtonBgDark}"/>
