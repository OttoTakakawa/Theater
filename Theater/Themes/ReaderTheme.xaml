    <SolidColorBrush x:Key="Brush.Reader.ButtonPressedBg" Color="{StaticResource Color.Reader.ButtonPressedBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ButtonPressedBorder" Color="{StaticResource Color.Reader.ButtonPressedBorder}"/>
    <SolidColorBrush x:Key="Brush.Reader.ComboBoxBg" Color="{StaticResource Color.Reader.ComboBoxBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ComboBoxHoverBg" Color="{StaticResource Color.Reader.ComboBoxHoverBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ComboBoxHoverBorder" Color="{StaticResource Color.Reader.ComboBoxHoverBorder}"/>
    <SolidColorBrush x:Key="Brush.Reader.PopupBg" Color="{StaticResource Color.Reader.PopupBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.PopupBorder" Color="{StaticResource Color.Reader.PopupBorder}"/>
