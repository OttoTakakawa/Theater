    <SolidColorBrush x:Key="Brush.Reader.ItemSelectedBg" Color="{StaticResource Color.Reader.ItemSelectedBg}"/>
    <SolidColorBrush x:Key="Brush.Reader.ItemSelectedBorder" Color="{StaticResource Color.Reader.ItemSelectedBorder}"/>
